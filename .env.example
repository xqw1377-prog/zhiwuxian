# 梦校航标（应用内填写，非环境变量）需包含：
#   现就读学校、现就读所在地、目标院校所在地、目标院校、专业、年级、入学时间
# 国内梦校（如清华）将自动切换高考/竞赛科目轨，不再显示托福/SAT 硬指标。

# =============================================================================
# WUXIAN 环境变量标准模板
# =============================================================================
#
# 使用方式：
#   1. 复制本文件为项目根目录的 .env（与 package.json 同级）
#      PowerShell:  Copy-Item .env.example .env
#   2. 将下方「必填」项中的占位符替换为你的真实密钥
#   3. 在项目根目录执行 npm run server 并重启服务
#
# 加载顺序（server/load-env.ts）：
#   ./.env  →  ./src/.env（仅填充 .env 中未出现的变量）
# 建议：只维护根目录 .env，迁移完成后可删除或清空 src/.env
#
# 自测：npx tsx scripts/test-llm-keys.ts
# =============================================================================

# ── 服务 ─────────────────────────────────────────────────────────────────────
PORT=3401
NODE_ENV=development
# 平板 App 构建（在 web/ 目录，见 docs/mobile-tablet.md）
# VITE_API_BASE=https://api.yourdomain.com
# VITE_LEGAL_OPERATOR=某某教育科技有限公司
# VITE_LEGAL_EMAIL=support@yourdomain.com

# 商用生产：NODE_ENV=production（启动时 Readiness 校验，见 docs/commercial-launch.md）
# WUXIAN_CORS_ORIGIN=https://你的前端域名
# WUXIAN_PAYMENT_MODE=live
# WUXIAN_PAYMENT_WEBHOOK_SECRET=强随机密钥（勿用 dev-local-secret）
# ZHI 主动巡检：距上次主动触达多少小时后进入「进度巡检」（默认 2，原逻辑约 6）
WUXIAN_PROACTIVE_PATROL_HOURS=2

# ── DeepSeek（对话 / JSON / 大部分 ZHI 算力）【必填其一：DeepSeek 或 OpenAI】──
WUXIAN_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-替换为你的DeepSeek密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 官方可用：deepseek-chat | deepseek-reasoner（勿用 deepseek-v4pro 等未上线名称）
WUXIAN_DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MODEL=deepseek-chat
WUXIAN_DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ── 通义千问 / DashScope（视觉多模态、摄影拦截优先）【建议填写】──────────────
# 与 DEEPSEEK 并存：有千问时视觉走千问，否则回退 DeepSeek
QWEN_API_KEY=sk-替换为你的通义千问密钥
# 也可用：DASHSCOPE_API_KEY=（与 QWEN_API_KEY 二选一）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 文本：qwen-plus | qwen-turbo  视觉：qwen-vl-max | qwen-vl-plus（勿用 qianwen3.6plus）
WUXIAN_QWEN_VISION_MODEL=qwen-vl-max

# ── OpenAI（可选：WUXIAN_LLM_PROVIDER=openai 或 Whisper 语音转写）──────────
# OPENAI_API_KEY=sk-替换为你的OpenAI密钥
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# WUXIAN_OPENAI_MODEL=gpt-4o-mini
# WUXIAN_WHISPER_MODEL=whisper-1

# ── 安全与鉴权 ───────────────────────────────────────────────────────────────
# 生产必填 ≥32 字符随机串；开发可暂用下方占位
DB_ENCRYPTION_KEY=dev-local-change-me-32chars-min!!
WUXIAN_SESSION_TTL_DAYS=30
# 开发默认放宽鉴权；生产请设为 0 或删除
# WUXIAN_AUTH_RELAXED=1
# WUXIAN_CORS_ORIGIN=http://localhost:5173

# ── 支付（本地开发）──────────────────────────────────────────────────────────
WUXIAN_PAYMENT_MODE=simulate
WUXIAN_PAYMENT_WEBHOOK_SECRET=dev-local-secret
PAYMENT_WEBHOOK_SECRET=dev-local-secret
# STRIPE_WEBHOOK_SECRET=
# WECHAT_PAY_API_KEY=

# ── 其它（一般保持默认即可）──────────────────────────────────────────────────
WUXIAN_TELEMETRY_RETENTION_DAYS=90
WUXIAN_SHOW_MENTOR_SHELL=1
WUXIAN_LIFETIME_CODES=
WUXIAN_SHARES_REQUIRE_TOKEN=0
# 家长微信战报 H5：/#/parent/:studentId?token=
# WUXIAN_PARENT_LINK_TOKEN=强随机密钥
# WECHAT_COMPANION_WEBHOOK_URL=https://你的微信中转网关
# WUXIAN_FRONTEND_URL=https://你的前端域名
# WUXIAN_WECHAT_PAY_H5_URL=https://pay.example.com/h5?orderId={orderId}&userId={userId}
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# RESEND_API_KEY=re_...（密码找回邮件）
# WUXIAN_EMAIL_FROM=WUXIAN ZHI <noreply@yourdomain.com>
# WUXIAN_SHARES_SIGNING_KEY=
# WUXIAN_DATA_DIR=./production_data
# WUXIAN_SHARES_DIR=./static_shares
# YT_DLP_PATH=yt-dlp

# ── 限流（可选）──────────────────────────────────────────────────────────────
# WUXIAN_RATE_WINDOW_MS=60000
# WUXIAN_RATE_ASSIMILATE_PER_MIN=12
# WUXIAN_RATE_VIDEO_PER_MIN=6
# WUXIAN_RATE_PAYMENT_PER_MIN=30
# WUXIAN_RATE_GLOBAL_API_PER_MIN=120
