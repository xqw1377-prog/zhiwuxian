{
  "name": "wuxian-engine",
  "version": "3.5.0",
  "private": true,
  "description": "WUXIAN 双轴逆向拆解与动态重算核心引擎",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "server": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "build:server": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/server/index.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "openclaw": "python openclaw/skills/course_auditor_skill.py",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:p0": "tsx scripts/e2e-p0.ts",
    "e2e:gateway-warp": "tsx scripts/e2e-gateway-warp.ts",
    "e2e:toefl-loop": "tsx scripts/e2e-toefl-loop.ts",
    "e2e:domestic-loop": "tsx scripts/e2e-domestic-loop.ts",
    "e2e:k12-loop": "tsx scripts/e2e-k12-loop.ts",
    "e2e:user-journey": "tsx scripts/e2e-user-journey.ts",
    "e2e:tablet-loop": "tsx scripts/e2e-tablet-loop.ts",
    "reconcile:payments": "tsx scripts/reconcile-warp-orders.ts",
    "ops:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-databases.ps1",
    "ops:health": "powershell -ExecutionPolicy Bypass -File scripts/health-watch.ps1",
    "migrate:pathway": "tsx scripts/migrate-pathway.ts",
    "metrics:fold-time": "tsx scripts/metrics-fold-time-report.ts",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern dist --ignore-pattern node_modules --ignore-pattern legacy --ignore-pattern data",
    "lint:fix": "eslint . --ext .ts,.tsx --fix --ignore-pattern dist --ignore-pattern node_modules --ignore-pattern legacy --ignore-pattern data",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build:web",
    "deploy:check": "tsx scripts/deploy-check.ts",
    "e2e:staging": "tsx scripts/e2e-staging.ts",
    "e2e:auth-prod": "tsx scripts/e2e-auth-production.ts",
    "e2e:svg-security": "tsx scripts/e2e-svg-security.ts",
    "e2e:real-url": "tsx scripts/e2e-real-url.ts",
    "e2e:http-real-url": "tsx scripts/e2e-http-real-url.ts",
    "e2e:wave1": "tsx scripts/e2e-wave1.ts",
    "build:web": "npm install --prefix web && npm run build --prefix web",
    "build:mobile": "npm install --prefix web && npm run build:mobile --prefix web",
    "mobile:sync": "npm run build:mobile --prefix web && npm exec --prefix web -- cap sync",
    "mobile:android": "npm run mobile:sync && npm exec --prefix web -- cap open android",
    "mobile:ios": "npm run mobile:sync && npm exec --prefix web -- cap open ios",
    "android:release": "powershell -ExecutionPolicy Bypass -File scripts/android-release.ps1",
    "dev:web": "npm run dev --prefix web",
    "desktop": "npm run dev --prefix electron",
    "desktop:install": "npm install --prefix electron",
    "desktop:legacy": "npm run start --prefix desktop"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.862.0",
    "@aws-sdk/s3-request-presigner": "^3.862.0",
    "@napi-rs/canvas": "^1.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/instrumentation-express": "^0.66.0",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "openai": "^6.38.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "stripe": "^22.1.1",
    "uuid": "^14.0.0",
    "web-vitals": "^5.2.0",
    "zod": "^3.25.76"
  }
}
