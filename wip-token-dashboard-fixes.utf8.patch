+    '鈶?鐩磋寤烘瀯锛氱被姣?鍥剧ず寤虹珛绗竴鍗拌薄',
+    '鈶?褰㈠紡鍖栵細缁欏嚭瀹氫箟銆佸叕寮忔垨鍒ゅ畾鏉′欢',
+    '鈶?渚嬮婕旂ず锛氬畬鏁翠功鍐欏叧閿楠?,
+    '鈶?鏄撻敊棰勮锛氬垪鍑?1锝? 涓珮棰戦敊鍥?,
+    '鈶?闅忓爞楠屾敹锛? 棰樻楠屾槸鍚︾湡浼氾紙闈炶儗绛旀锛?,
+  ];
+
+  return {
+    knowledgePoint: kp?.name ?? knowledgePointLabel,
+    subjectId,
+    bloom,
+    bloomGuidance: BLOOM_GUIDANCE[bloom] ?? BLOOM_GUIDANCE.understand,
+    prerequisites,
+    teachingSteps,
+  };
+}
+
+export function formatPedagogyBlock(brief: PedagogyBrief): string {
+  return [
+    `銆愭暀瀛︽硶銆戝竷椴佸灞傜骇锛?{brief.bloom} 鈥?${brief.bloomGuidance}`,
+    brief.prerequisites.length ? `銆愬厛淇€?{brief.prerequisites.join('銆?)}` : '銆愬厛淇€戞寜骞寸骇甯歌瘑鑷',
+    `銆愯鎺堟楠ゃ€?{brief.teachingSteps.join(' 鈫?')}`,
+  ].join('\n');
+}
+
+export function suggestWeakKnowledgePoints(subjectId: string, limit = 5): KnowledgePointEntry[] {
+  return listKnowledgePointsForSubject(subjectId).slice(-limit);
+}
