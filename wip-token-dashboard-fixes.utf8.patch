+  const enrichedCatalog = activeEnrichedCatalog(subjectId);
+  const statsAll = countEnrichmentStats(allCatalog);
+  const statsSubject = countEnrichmentStats(allCatalog, subjectId);
+
+  const scored = enrichedCatalog
+    .map((row) => scoreCoursewareWithBoost(row, needs, boost, learner))
+    .filter((m): m is CoursewareMatchDto => m != null)
+    .filter((m) => subjectIdsEquivalent(m.courseware.subject, focus))
+    .sort((a, b) => b.matchScore - a.matchScore);
+
+  const matches = scored.slice(0, limit);
+  const libraryGap =
+    matches.length === 0
+      ? buildCoursewareLibraryGapMessage({
