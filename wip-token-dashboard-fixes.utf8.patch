+/**
+ * ZHI 路 鏁欐潗鐩綍 AI 绮炬爣锛氱珷鑺傜煡璇嗙偣 + 骞寸骇/璇剧翰鏍囩
+ */
+
+import {
+  getTextbookById,
+  parseTextbookOutline,
+  upsertTextbookCatalog,
+  listTextbookIdsNeedingEnrichment,
+  type TextbookChapterOutline,
+} from '../db/zhi-textbook-catalog-schema';
+import { getSchoolAnchorProfile } from '../db/zhi-cloud-schema';
+import { buildLearnerProfile } from './learner-profile';
+import { gatewayJsonCompletion } from './llm-gateway';
+import { normalizeTagProfile, type ResourceTagProfile } from './resource-tag-profile';
+import { coursewareSubjectFromRequest } from './subject-id-resolver';
+import { canonicalizeKnowledgePointLabel } from './knowledge-point-registry';
+
+const TEXTBOOK_ENRICH_SYSTEM = `浣犳槸 ZHI 鏁欐潗鏍囨敞瀹樸€傛牴鎹暀鏉愪功鍚嶃€佸嚭鐗堢ぞ涓庣幇鏈夌珷鑺傜洰褰曪紝杈撳嚭绮炬爣 JSON锛?+{
+  "subjectId": "math|physics|chemistry|english|...",
+  "gradeBand": "楂樹竴|楂樹簩|楂樹笁|鍒濅笁|閫氱敤",
+  "curriculumTrack": "cn_gaokao|intl_ib_ap|intl_us_uk|k12_stage|undetermined",
+  "provinceOrRegion": "濡傦細婀栧崡 鎴?null",
+  "knowledgeSummary": "20瀛楀唴鏈功瀹氫綅",
+  "chapters": [
+    { "index": 1, "title": "绔犳爣棰?, "knowledgePoints": ["鍙獙鏀惰€冪偣1","鑰冪偣2"] }
+  ]
+}
+瑙勫垯锛氭瘡绔?3-8 涓叿浣撶煡璇嗙偣锛涗笌涔﹀悕瀛︾涓€鑷达紱鍥藉唴楂樹腑榛樿 cn_gaokao銆俙;
+
+export type EnrichTextbookResult = {
+  ok: boolean;
+  catalogId: string;
+  reason: string;
+};
+
+export async function enrichTextbookById(
+  catalogId: string,
+  opts?: { userId?: string },
+): Promise<EnrichTextbookResult> {
+  const row = getTextbookById(catalogId);
+  if (!row) return { ok: false, catalogId, reason: '鏁欐潗涓嶅瓨鍦? };
+
+  const uid = opts?.userId?.trim() || row.user_id;
+  const anchor = getSchoolAnchorProfile(uid);
+  const learner = buildLearnerProfile(uid);
+  const outline = parseTextbookOutline(row);
+  const outlineSummary = outline
+    .slice(0, 12)
+    .map((c) => `绗?{c.index}绔?${c.title}锛?{c.knowledgePoints.join('銆?) || '锛堝緟琛ワ級'}`)
+    .join('\n');
+
+  const userPayload = [
+    `涔﹀悕锛?{row.title}`,
+    `鍑虹増绀撅細${row.publisher}`,
+    row.subject ? `瀛︾鎻愮ず锛?{row.subject}` : '',
+    anchor?.currentGrade ? `骞寸骇锛?{anchor.currentGrade}` : learner?.gradeBand ? `骞寸骇锛?{learner.gradeBand}` : '',
+    learner?.provinceOrRegion ? `鐪佷唤锛?{learner.provinceOrRegion}` : '',
+    `鐜版湁鐩綍锛歕n${outlineSummary || '锛堢┖锛岃鎸変功鍚嶆帹鏂悎鐞嗙珷鑺傜粨鏋勶級'}`,
+  ]
+    .filter(Boolean)
+    .join('\n');
+
+  const gw = await gatewayJsonCompletion<{
+    subjectId?: string;
+    gradeBand?: string;
+    curriculumTrack?: ResourceTagProfile['curriculumTrack'];
+    provinceOrRegion?: string | null;
+    knowledgeSummary?: string;
+    chapters?: TextbookChapterOutline[];
+  }>(uid, [
+    { role: 'system', content: TEXTBOOK_ENRICH_SYSTEM },
+    { role: 'user', content: userPayload },
+  ], {
+    traceId: `textbook_enrich_${catalogId.slice(0, 8)}`,
+    maxTokens: 1400,
+    temperature: 0.25,
+  });
+
+  if (!gw.chargeOk || !gw.data?.chapters?.length) {
+    return { ok: false, catalogId, reason: gw.error || 'LLM 鏍囨敞澶辫触' };
+  }
+
+  const profile = normalizeTagProfile({
+    subjectId: coursewareSubjectFromRequest(gw.data.subjectId ?? row.subject ?? 'math'),
+    gradeBand: gw.data.gradeBand ?? learner?.gradeBand ?? '閫氱敤',
+    curriculumTrack: gw.data.curriculumTrack ?? learner?.curriculumTrack ?? 'cn_gaokao',
+    provinceOrRegion: gw.data.provinceOrRegion ?? learner?.provinceOrRegion ?? null,
+    topicTags: [],
+    knowledgePoints: [],
+    examAlign: [],
+    difficulty: null,
+    audience: ['high_school'],
+    summary: gw.data.knowledgeSummary ?? row.title,
+  });
+
+  const chapters: TextbookChapterOutline[] = gw.data.chapters
+    .map((ch, i) => ({
+      index: Number(ch.index ?? i + 1),
+      title: String(ch.title ?? `绗?{i + 1}绔燻).slice(0, 80),
+      knowledgePoints: (ch.knowledgePoints ?? [])
+        .map((k) => String(k).trim())
+        .filter(Boolean)
+        .map((k) => canonicalizeKnowledgePointLabel(profile.subjectId, k) ?? k)
+        .filter(Boolean)
+        .filter((k, idx, arr) => arr.indexOf(k) === idx)
+        .slice(0, 12),
+    }))
+    .filter((c) => c.title);
+
+  upsertTextbookCatalog({
+    userId: row.user_id,
+    title: row.title,
+    publisher: row.publisher,
+    subject: profile.subjectId,
+    edition: row.edition ?? undefined,
+    chapters,
+    progressChapter: row.progress_chapter ?? undefined,
+    progressPct: row.progress_pct ?? undefined,
+    knowledgeSummary: profile.summary,
+    gradeBand: profile.gradeBand,
+    curriculumTrack: profile.curriculumTrack,
+    provinceOrRegion: profile.provinceOrRegion,
+    enrichmentStatus: 'enriched',
+  });
+
+  return {
+    ok: true,
+    catalogId,
+    reason: `宸叉爣娉?${chapters.length} 绔?路 ${profile.gradeBand} 路 ${profile.curriculumTrack}`,
+  };
+}
+
