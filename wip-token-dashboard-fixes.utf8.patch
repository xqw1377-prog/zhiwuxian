+async function loadLocales() {
+  const resources: Record<string, { translation: Record<string, unknown> }> = {};
+
+  const [zhModule, enModule] = await Promise.all([
+    import('./locales/zh'),
+    import('./locales/en'),
+  ]);
+  resources.zh = zhModule.default as unknown as { translation: Record<string, unknown> };
+  resources.en = enModule.default as unknown as { translation: Record<string, unknown> };
+
+  const extra = await Promise.allSettled([
+    import('./locales/ja'),
+    import('./locales/ko'),
+    import('./locales/th'),
+  ]);
+  const [jaModule, koModule, thModule] = extra;
+  if (jaModule.status === 'fulfilled') resources.ja = jaModule.value.default as unknown as { translation: Record<string, unknown> };
+  if (koModule.status === 'fulfilled') resources.ko = koModule.value.default as unknown as { translation: Record<string, unknown> };
+  if (thModule.status === 'fulfilled') resources.th = thModule.value.default as unknown as { translation: Record<string, unknown> };
+
+  return resources;
+}
+
+loadLocales().then((resources) => {
+  i18n.use(initReactI18next).init({
+    resources,
+    lng: getInitialLang(),
+    fallbackLng: 'zh',
+    interpolation: { escapeValue: false },
+  });
