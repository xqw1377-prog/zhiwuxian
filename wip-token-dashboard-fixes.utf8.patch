index 0000000..484c5f5
--- /dev/null
+++ b/scripts/e2e-staging.ts
@@ -0,0 +1,72 @@
+/**
+ * 鍟嗙敤棰勫彂 E2E 濂椾欢锛圥1锛夛細渚濇璺?p0 + 璺緞鍐掔儫 + 鐢熶骇閴存潈 + 鐢ㄦ埛鏃呯▼
+ *
+ * 杩愯锛歯pm run e2e:staging
+ * - 榛樿瑕佹眰鏈満宸叉湁 `npm run server`锛?401锛夛紝渚?p0/domestic/k12
+ * - auth-prod / user-journey 鑷惎涓存椂 production 瀹炰緥
+ */
+
+import { spawn } from 'child_process';
+import { join } from 'path';
+
+const ROOT = join(__dirname, '..');
+
+const STEPS: Array<{ name: string; script: string; needsMainServer: boolean }> = [
+  { name: 'e2e:p0', script: 'e2e:p0', needsMainServer: true },
+  { name: 'e2e:domestic-loop', script: 'e2e:domestic-loop', needsMainServer: true },
+  { name: 'e2e:k12-loop', script: 'e2e:k12-loop', needsMainServer: true },
+  { name: 'e2e:auth-prod', script: 'e2e:auth-prod', needsMainServer: false },
+  { name: 'e2e:user-journey', script: 'e2e:user-journey', needsMainServer: false },
+];
+
+async function healthOk(base: string): Promise<boolean> {
+  try {
+    const res = await fetch(`${base}/api/health`);
+    return res.ok;
+  } catch {
+    return false;
+  }
+}
+
+function runNpmScript(script: string): Promise<number> {
+  return new Promise((resolve) => {
+    const proc = spawn('npm', ['run', script], {
+      cwd: ROOT,
+      shell: true,
+      stdio: 'inherit',
+      env: process.env,
+    });
+    proc.on('close', (code) => resolve(code ?? 1));
