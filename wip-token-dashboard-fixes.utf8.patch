+export function matchCoursewareForSubject(
+  userId: string,
+  subjectId: string,
+  opts?: { hint?: string; knowledgePoints?: string[]; limit?: number },
+): SubjectCoursewareMatchResult {
+  const uid = userId.trim();
+  const limit = Math.max(1, Math.min(12, opts?.limit ?? 6));
