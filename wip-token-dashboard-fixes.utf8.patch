diff --git a/web/src/lib/theme-prefs.ts b/web/src/lib/theme-prefs.ts
new file mode 100644
index 0000000..d12f717
--- /dev/null
+++ b/web/src/lib/theme-prefs.ts
@@ -0,0 +1,25 @@
+export type WuxianTheme = 'light' | 'comfort' | 'competitive';
+
+const THEME_KEY = 'wuxian_theme';
+
+export function getTheme(): WuxianTheme {
+  const raw = localStorage.getItem(THEME_KEY);
+  if (raw === 'competitive') return 'competitive';
+  if (raw === 'comfort') return 'comfort';
+  if (raw === 'light') return 'light';
+  return 'light';
+}
+
+export function setTheme(theme: WuxianTheme): void {
+  localStorage.setItem(THEME_KEY, theme);
+}
+
+export function applyTheme(theme: WuxianTheme): void {
+  document.documentElement.dataset.theme = theme;
+}
+
+export function initTheme(): WuxianTheme {
+  const t = getTheme();
+  applyTheme(t);
+  return t;
+}
