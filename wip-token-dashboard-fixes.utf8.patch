@@ -0,0 +1,53 @@
+import { SqliteEngine } from './sqlite-engine';
+import { PgEngine } from './pg-engine';
+import type { DbEngine, DbEngineType } from './types';
+
+export type { DbEngine, DbEngineType, Statement, StatementResult } from './types';
+
+let coreEngine: DbEngine | null = null;
+let learningEngine: DbEngine | null = null;
+
+export function detectDbEngine(): DbEngineType {
+  return process.env.DATABASE_URL ? 'postgresql' : 'sqlite';
+}
+
+export function getCoreEngine(): DbEngine {
+  if (!coreEngine) {
+    const { getDataDir, getCoreDbPath } = require('../data-path');
+    const type = detectDbEngine();
+    if (type === 'postgresql') {
+      const dbUrl = process.env.DATABASE_URL!;
+      const coreUrl = process.env.DATABASE_CORE_URL || dbUrl;
+      console.log(`[DB] 鏍稿績鏁版嵁搴撳紩鎿? PostgreSQL 鈫?${coreUrl.replace(/\/\/.*@/, '//***@')}`);
+      coreEngine = new PgEngine(coreUrl);
+    } else {
+      const dbPath = getCoreDbPath();
+      console.log(`[DB] 鏍稿績鏁版嵁搴撳紩鎿? SQLite 鈫?${dbPath}`);
+      coreEngine = new SqliteEngine(dbPath);
+    }
+  }
+  return coreEngine;
+}
+
+export function getLearningEngine(): DbEngine {
+  if (!learningEngine) {
+    const { getDataDir, getLearningDbPath } = require('../data-path');
+    const type = detectDbEngine();
+    if (type === 'postgresql') {
+      const dbUrl = process.env.DATABASE_URL!;
+      const learningUrl = process.env.DATABASE_LEARNING_URL || dbUrl;
+      console.log(`[DB] 瀛︿範鏁版嵁搴撳紩鎿? PostgreSQL 鈫?${learningUrl.replace(/\/\/.*@/, '//***@')}`);
+      learningEngine = new PgEngine(learningUrl);
+    } else {
+      const dbPath = getLearningDbPath();
+      console.log(`[DB] 瀛︿範鏁版嵁搴撳紩鎿? SQLite 鈫?${dbPath}`);
+      learningEngine = new SqliteEngine(dbPath);
+    }
+  }
+  return learningEngine;
+}
+
+export function resetEnginesForTest(): void {
+  coreEngine = null;
+  learningEngine = null;
+}
diff --git a/server/db/pg-engine.ts b/server/db/pg-engine.ts
new file mode 100644
index 0000000..d6cdb8c
--- /dev/null
+++ b/server/db/pg-engine.ts
@@ -0,0 +1,112 @@
+import { Pool, PoolClient } from 'pg';
+import type { DbEngine, Statement, StatementResult } from './types';
+
+export class PgEngine implements DbEngine {
+  private pool: Pool;
+  private schema: string;
+
+  constructor(databaseUrl: string) {
+    this.schema = process.env.PG_SCHEMA || 'public';
+    this.pool = new Pool({
+      connectionString: databaseUrl,
+      max: Number(process.env.PG_POOL_MAX) || 20,
+      idleTimeoutMillis: 30000,
+      connectionTimeoutMillis: 5000,
+    });
+
+    this.pool.on('error', (err) => {
+      console.error('[PG] 杩炴帴姹犲紓甯?', err.message);
+    });
+  }
+
+  async exec(sql: string): Promise<void> {
+    const client = await this.pool.connect();
+    try {
+      await client.query(`SET search_path TO ${this.schema}`);
+      await client.query(sql);
+    } finally {
+      client.release();
+    }
+  }
+
+  prepare(sql: string): Statement {
+    const normalizedSql = this.normalizeSql(sql);
+    return {
+      run: async (...params: unknown[]): Promise<StatementResult> => {
+        const client = await this.pool.connect();
+        try {
+          await client.query(`SET search_path TO ${this.schema}`);
+          const result = await client.query(normalizedSql, params);
+          return {
+            changes: result.rowCount ?? 0,
+            lastInsertRowid: result.rows?.[0]?.id ?? 0,
+          };
+        } finally {
+          client.release();
+        }
+      },
+      get: async <T = Record<string, unknown>>(...params: unknown[]): Promise<T | undefined> => {
+        const client = await this.pool.connect();
+        try {
+          await client.query(`SET search_path TO ${this.schema}`);
+          const result = await client.query(normalizedSql, params);
+          return result.rows[0] as T | undefined;
+        } finally {
+          client.release();
+        }
+      },
+      all: async <T = Record<string, unknown>>(...params: unknown[]): Promise<T[]> => {
+        const client = await this.pool.connect();
+        try {
+          await client.query(`SET search_path TO ${this.schema}`);
+          const result = await client.query(normalizedSql, params);
+          return result.rows as T[];
+        } finally {
+          client.release();
+        }
+      },
+    };
+  }
+
+  async close(): Promise<void> {
+    await this.pool.end();
+  }
+
+  getSqliteNative<T = unknown>(): T | null {
+    return null;
+  }
+
+  /** SQLite 鈫?PG 鏂硅█杞崲 */
+  private normalizeSql(sql: string): string {
+    const result = sql
+      // datetime('now') 鈫?NOW()
+      .replace(/\bdatetime\s*\(\s*'now'\s*\)\s*/gi, "NOW()")
+      // strftime('%s', 'now') 鈫?EXTRACT(EPOCH FROM NOW())
+      .replace(/strftime\s*\(\s*'%s'\s*,\s*'now'\s*\)\s*/gi, "EXTRACT(EPOCH FROM NOW())")
+      // strftime('%s', column) 鈫?EXTRACT(EPOCH FROM column)
+      .replace(/strftime\s*\(\s*'%s'\s*,\s*(\w+)\)/gi, "EXTRACT(EPOCH FROM $1)")
+      // CURRENT_TIMESTAMP (same in PG)
+      // INSERT OR IGNORE 鈫?INSERT ... ON CONFLICT DO NOTHING
+      .replace(/\bINSERT\s+OR\s+IGNORE\b/gi, "INSERT")
+      .replace(/\bINSERT\s+OR\s+REPLACE\b/gi, "INSERT")
+      // ON CONFLICT... DO UPDATE SET excluded. 鈫?EXCLUDED. (uppercase for PG)
+      .replace(/\.excluded\./gi, '.EXCLUDED.')
+      // sqlite_master 鈫?information_schema
+      .replace(/\bsqlite_master\b/gi, "information_schema.tables")
+      // PRAGMA table_info 鈫?information_schema.columns
+      .replace(/PRAGMA\s+table_info\s*\(\s*(\w+)\s*\)/gi, (_, table) =>
+        `SELECT column_name AS name FROM information_schema.columns WHERE table_name = '${table}'`)
+      // LIKE with no ESCAPE (same)
+      // Remove COLLATE clauses
+      .replace(/\bCOLLATE\s+\w+\b/gi, '')
+      // Integer PRIMARY KEY 鈫?SERIAL for auto-increment
+      .replace(/(\w+)\s+INTEGER\s+PRIMARY\s+KEY\s+AUTOINCREMENT/gi, "$1 SERIAL PRIMARY KEY")
+      .replace(/\bAUTOINCREMENT\b/gi, '')
+      // TEXT PRIMARY KEY 鈫?keep as is
+      // REAL 鈫?DOUBLE PRECISION
+      .replace(/\bREAL\b/gi, "DOUBLE PRECISION")
+    ;
+
+    return result;
+  }
+}
diff --git a/server/db/sqlite-engine.ts b/server/db/sqlite-engine.ts
new file mode 100644
index 0000000..7e6a5da
--- /dev/null
+++ b/server/db/sqlite-engine.ts
@@ -0,0 +1,51 @@
+import Database from 'better-sqlite3';
+import type { DbEngine, Statement, StatementResult } from './types';
+
+export class SqliteEngine implements DbEngine {
+  private db: Database.Database;
+
+  constructor(dbPath: string) {
+    this.db = new Database(dbPath);
+    this.db.pragma('journal_mode = WAL');
+    this.db.pragma('busy_timeout = 5000');
+  }
+
+  async exec(sql: string): Promise<void> {
+    this.db.exec(sql);
+  }
+
+  prepare(sql: string): Statement {
+    const stmt = this.db.prepare(sql);
+    return {
+      run: (...params: unknown[]): Promise<StatementResult> => {
+        const result = stmt.run(...params);
+        return Promise.resolve({ changes: result.changes, lastInsertRowid: result.lastInsertRowid });
+      },
+      get: <T = Record<string, unknown>>(...params: unknown[]): Promise<T | undefined> => {
+        const result = stmt.get(...params) as T | undefined;
+        return Promise.resolve(result);
+      },
+      all: <T = Record<string, unknown>>(...params: unknown[]): Promise<T[]> => {
+        const result = stmt.all(...params) as T[];
+        return Promise.resolve(result);
+      },
+    };
+  }
+
+  async close(): Promise<void> {
+    this.db.close();
+  }
+
+  getSqliteNative<T = unknown>(): T | null {
+    return this.db as unknown as T;
+  }
+
+  transaction<T>(fn: (...args: unknown[]) => T): (...args: unknown[]) => Promise<T> {
+    const tx = this.db.transaction(fn);
+    return async (...args: unknown[]): Promise<T> => tx(...args);
+  }
+
+  get nativeDb(): Database.Database {
+    return this.db;
+  }
+}
