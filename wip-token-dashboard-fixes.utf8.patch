+export function buildPedagogyBrief(subjectId: string, knowledgePointLabel: string): PedagogyBrief {
+  const kp = findKnowledgePoint(subjectId, knowledgePointLabel);
+  const bloom = kp?.bloom ?? 'understand';
+  const prereqIds = kp ? PREREQUISITES[kp.id] ?? [] : [];
