@@ -0,0 +1,26 @@
+# 负载测试
+
+使用 [k6](https://k6.io) 进行负载测试。
+
+## 测试场景
+
+| 文件 | 覆盖范围 | 并发目标 |
+|------|---------|----------|
+| `llm-gateway.test.js` | LLM 网关（ZHI Token 预扣/结算 / 余额不足） | 100 |
+| `auth.test.js` | 登录 / 注册 / 会话恢复 | 20 |
+| `core-api.test.js` | 钱包 / 用户 / 管理 API | 30 |
+
+## 运行
+
+```bash
+# 安装 k6（Windows: winget install k6, macOS: brew install k6, Linux: 见 k6.io/docs）
+# 然后用管理员 token 运行
+TOKEN=your_admin_token BASE_URL=http://localhost:3400 bash deploy/loadtest/run-all.sh
+```
+
+## 性能目标
+
+- LLM 网关 p95 < 30s（含 LLM 推理时间）
+- 认证 API p95 < 3s
+- 核心 API p95 < 2s
+- 错误率 < 10%
diff --git a/deploy/loadtest/auth.test.js b/deploy/loadtest/auth.test.js
new file mode 100644
index 0000000..c911681
--- /dev/null
+++ b/deploy/loadtest/auth.test.js
@@ -0,0 +1,63 @@
+import http from 'k6/http';
+import { check, sleep, group } from 'k6';
+import { Rate, Trend } from 'k6/metrics';
+
+const BASE_URL = __ENV.BASE_URL || 'http://localhost:3400';
+
+const errorRate = new Rate('errors');
+const authLatency = new Trend('auth_latency_ms');
+const sessionRestoreLatency = new Trend('session_restore_ms');
+
+const REGISTER_CREDENTIALS = [
+  { username: 'loadtest_alice', password: 'TestPass123!', email: 'alice@loadtest.local' },
+  { username: 'loadtest_bob', password: 'TestPass123!', email: 'bob@loadtest.local' },
+  { username: 'loadtest_charlie', password: 'TestPass123!', email: 'charlie@loadtest.local' },
+];
+
+const LOGIN_CREDENTIALS = [
+  { username: 'admin', password: 'admin123' },
+  { username: 'testuser', password: 'test123' },
+];
+
+export const options = {
+  stages: [
+    { duration: '30s', target: 5 },
+    { duration: '1m', target: 20 },
+    { duration: '30s', target: 0 },
+  ],
+  thresholds: {
+    errors: ['rate<0.15'],
+    auth_latency_ms: ['p(95)<3000'],
+    http_req_failed: ['rate<0.05'],
+  },
+};
+
+export default function () {
+  group('Authentication', () => {
+    const scenario = Math.random();
+    const payload = scenario < 0.3 ? REGISTER_CREDENTIALS[Math.floor(Math.random() * REGISTER_CREDENTIALS.length)]
+      : LOGIN_CREDENTIALS[Math.floor(Math.random() * LOGIN_CREDENTIALS.length)];
+
+    const isRegister = scenario < 0.3;
+    const endpoint = isRegister ? `${BASE_URL}/api/v1/auth/register` : `${BASE_URL}/api/v1/auth/login`;
+
+    const res = http.post(endpoint, JSON.stringify(payload), {
+      headers: { 'Content-Type': 'application/json' },
+    });
+
+    authLatency.add(res.timings.duration);
+
+    if (res.status === 200) {
+      check(res, {
+        'auth success': () => res.status === 200,
+        'has token': () => JSON.parse(res.body).token !== undefined || JSON.parse(res.body).data?.token !== undefined,
+        'has userId': () => JSON.parse(res.body).userId !== undefined || JSON.parse(res.body).data?.userId !== undefined,
+      });
+
+      if (Math.random() > 0.7) {
+        const token = JSON.parse(res.body).token || JSON.parse(res.body).data?.token || '';
+        if (token) {
+          const sessionRes = http.get(`${BASE_URL}/api/v1/auth/me`, {
+            headers: { Authorization: `Bearer ${token}` },
+          });
+          sessionRestoreLatency.add(sessionRes.timings.duration);
+          check(sessionRes, {
+            'session restore success': () => sessionRes.status === 200,
+            'has user data': () => JSON.parse(sessionRes.body).username !== undefined,
+          });
+        }
+      }
+    } else if (res.status === 409) {
+      check(res, { 'status is 409 (duplicate)': () => res.status === 409 });
+    } else if (res.status === 429) {
+      check(res, { 'status is 429 (rate limited)': () => res.status === 429 });
+    } else {
+      errorRate.add(1);
+    }
+  });
+
+  sleep(Math.random() * 2 + 1);
+}
