+import { gatewayJsonCompletion } from './llm-gateway';
+
+export interface EvaluationResult {
+  passed: boolean;
+  score: number;
+  feedback: string;
+  followUpQuestion: string | null;
+  correctAnswer: string;
+}
+
+/**
+ * 璇箟绾ф娴嬮璇勪及 鈥?鏇夸唬瀛楃涓茬簿纭尮閰?+ * 鏀寔锛氶儴鍒嗗垎銆佽В閲婁簡绛斿/绛旈敊鐨勫師鍥犮€佺敓鎴愯窡杩涜拷闂?+ * 浠呭湪浠ヤ笅鎯呭喌浣跨敤 LLM 璇勪及锛?+ *   1. 涓昏棰橈紙闂瓟棰樸€佸～绌洪銆乤ctive_qa锛?+ *   2. 閫夋嫨棰樹腑鐢ㄦ埛缁欏嚭浜嗚В閲婃€х瓟妗?+ *   3. 棣栨瀛楃涓插尮閰嶅け璐ュ悗 fallback
+ */
+export async function evaluateCheckpointSemantically(
+  userId: string,
+  question: string,
+  options: string[],
+  correctAnswer: string,
+  userAnswer: string,
+): Promise<EvaluationResult> {
+  const exactMatch = userAnswer.trim().toLowerCase() === correctAnswer.trim().toLowerCase();
+  if (exactMatch || (options.length > 0 && options.some(o => o.trim().toLowerCase() === userAnswer.trim().toLowerCase() && o.trim().toLowerCase() === correctAnswer.trim().toLowerCase()))) {
+    return {
+      passed: true,
+      score: 1.0,
+      feedback: '瀹屽叏姝ｇ‘锛?,
+      followUpQuestion: null,
+      correctAnswer,
+    };
+  }
+
+  if (options.length > 0) {
+    const userChoice = userAnswer.trim().toLowerCase();
+    const correctOption = correctAnswer.trim().toLowerCase();
+    const userPickedCorrect = options.some(o => o.trim().toLowerCase() === userChoice && o.trim().toLowerCase() === correctOption);
+    if (userPickedCorrect) {
+      return {
+        passed: true,
+        score: 1.0,
+        feedback: '姝ｇ‘锛?,
+        followUpQuestion: null,
+        correctAnswer,
+      };
+    }
+    const correctIdx = options.findIndex(o => o.trim().toLowerCase() === correctOption);
+    const userIdx = options.findIndex(o => o.trim().toLowerCase() === userChoice);
+    if (correctIdx >= 0 && userIdx >= 0) {
+      return {
+        passed: false,
+        score: 0,
+        feedback: `涓嶆纭€傛纭瓟妗堟槸: ${options[correctIdx]}`,
+        followUpQuestion: `浣犻€変簡 "${options[userIdx]}"锛岃兘鍚﹁璇翠綘涓轰粈涔堣涓鸿繖涓€夐」姝ｇ‘锛熸垜浠潵涓€璧峰垎鏋愪竴涓嬨€俙,
+        correctAnswer,
+      };
+    }
+  }
+
+  try {
+    const gw = await gatewayJsonCompletion<Record<string, unknown>>(userId, [
+      { role: 'system', content: [
+        '浣犳槸涓€涓弗璋ㄧ殑瀛︾鍔╂暀锛岃瘎浼板鐢熺瓟妗堟槸鍚﹁涔夌瓑鏁堜簬鏍囧噯绛旀銆?,
+        '杩斿洖 JSON锛屼笉瑕佸浣欐枃鏈細',
+        '{',
+        '  "passed": true/false,',
+        '  "score": 0.0-1.0,',
+        '  "feedback": "绠€瑕佽В閲婂閿欏師鍥狅紙20瀛楀唴锛?,',
+        '  "followUpQuestion": "濡傛灉閿欎簡锛岀敓鎴愪竴涓惎鍙戝紡杩介棶甯鐢熻嚜宸卞彂鐜伴敊璇紙20瀛楀唴锛夛紱濡傛灉瀵逛簡鍒欎负null"',
+        '}',
+      ].join('\n') },
+      { role: 'user', content: [
+        `棰樼洰锛?{question}`,
+        `鏍囧噯绛旀锛?{correctAnswer}`,
+        options.length > 0 ? `閫夐」锛?{options.join(' | ')}` : '',
+        `瀛︾敓绛旀锛?{userAnswer}`,
+      ].filter(Boolean).join('\n') },
+    ], {
+      traceId: `checkpoint_eval_${userId.slice(0, 8)}`,
+      maxTokens: 200,
+      temperature: 0.3,
+    });
+
+    const d = gw.data ?? {};
+    const score = Math.max(0, Math.min(1, Number(d.score ?? 0)));
+    const passed = score >= 0.5 || d.passed === true;
+    return {
+      passed,
+      score,
+      feedback: String(d.feedback ?? (passed ? '鍩烘湰姝ｇ‘' : '涓嶆纭?)),
+      followUpQuestion: d.followUpQuestion ? String(d.followUpQuestion) : null,
+      correctAnswer,
+    };
+  } catch {
+    return {
+      passed: false,
+      score: 0,
+      feedback: `姝ｇ‘绛旀鏄? ${correctAnswer}`,
+      followUpQuestion: null,
+      correctAnswer,
+    };
+  }
+}
+
+/**
+ * 楠岃瘉 LLM 鐢熸垚鐨勬暀瀛﹀唴瀹硅川閲?+ * 妫€鏌ワ細浜嬪疄姝ｇ‘鎬с€侀€昏緫鑷唇鎬с€佹槸鍚﹀寘鍚够瑙?+ */
+export async function validateLessonContent(
+  userId: string,
+  knowledgePoint: string,
+  coreTeaching: string,
+): Promise<{ valid: boolean; issues: string[]; score: number }> {
+  try {
+    const gw = await gatewayJsonCompletion<Record<string, unknown>>(userId, [
+      { role: 'system', content: [
+        '浣犳槸涓€涓暀瀛﹁川閲忓鏍稿憳銆傛鏌ヤ互涓嬫暀瀛﹀唴瀹规槸鍚﹀瓨鍦細',
+        '1. 浜嬪疄閿欒鎴栬繃鏃朵俊鎭?,
+        '2. 閫昏緫鐭涚浘',
+        '3. 涓庡父瑙佹暀鏉愪笉绗︾殑琛ㄨ堪',
+        '4. 闅惧害涓庣煡璇嗙偣涓嶅尮閰?,
+        '杩斿洖 JSON:',
+        '{"valid": true/false, "issues": ["闂1","闂2"], "score": 0-10}',
+      ].join('\n') },
+      { role: 'user', content: [
+        `鐭ヨ瘑鐐癸細${knowledgePoint}`,
+        `鏁欏鍐呭锛?{coreTeaching.slice(0, 1000)}`,
+      ].join('\n') },
+    ], {
+      traceId: `validate_${knowledgePoint.slice(0, 16)}`,
+      maxTokens: 300,
+      temperature: 0.2,
+    });
+
+    const d = gw.data ?? {};
+    return {
+      valid: d.valid !== false,
+      issues: Array.isArray(d.issues) ? d.issues.map(String) : [],
+      score: Math.max(0, Math.min(10, Number(d.score ?? 10))),
+    };
+  } catch {
+    return { valid: true, issues: [], score: 10 };
+  }
+}
