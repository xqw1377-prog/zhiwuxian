@@ -0,0 +1,44 @@
+import { describe, expect, it, beforeEach } from 'vitest';
+import { randomUUID } from 'crypto';
+import { getLearningDb, resetLearningDbForTests } from '../server/wuxian-learning-db';
+import { initializeZhiAssessmentSchema, saveAssessmentPaper } from '../src/db/zhi-assessment-schema';
+import { computeMasteryFold } from '../src/services/zhi-mastery-fold';
+
+describe('zhi-mastery-fold', () => {
+  beforeEach(() => {
+    resetLearningDbForTests();
+    initializeZhiAssessmentSchema();
+  });
+
+  it('鍚岀涓ゆ璇勪及鍙绠楁彁鍗?, () => {
+    const userId = `u-fold-${randomUUID().slice(0, 8)}`;
+    const paper = saveAssessmentPaper({
+      userId,
+      subjectId: 'math',
+      subjectName: '鏁板',
+      paperType: 'subject_unit',
+      title: '鍗曞厓鍗?,
+      questions: [{ id: 'q1', prompt: '1+1', type: 'short' }],
+    });
+
+    const db = getLearningDb();
+    const insertAttempt = (score: number) => {
+      db.prepare(
+        `INSERT INTO zhi_assessment_attempts (id, paper_id, user_id, answers_json, score_pct, created_at)
+         VALUES (?, ?, ?, '{}', ?, strftime('%s', 'now'))`,
+      ).run(randomUUID(), paper.id, userId, score);
+    };
+    insertAttempt(60);
+    insertAttempt(75);
+
+    const fold = computeMasteryFold(userId, 10);
+    expect(fold.sampleCount).toBe(1);
+    expect(fold.avgLiftPct).toBe(15);
+  });
+
+  it('鏃犺瘎浼版椂杩斿洖榛樿鎻愮ず', () => {
+    const fold = computeMasteryFold(`u-empty-${randomUUID().slice(0, 6)}`, 5);
+    expect(fold.sampleCount).toBe(0);
+    expect(fold.hint).toContain('璇勪及');
+  });
+});
