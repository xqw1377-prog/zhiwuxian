diff --git a/src/db/zhi-textbook-content-schema.ts b/src/db/zhi-textbook-content-schema.ts
new file mode 100644
index 0000000..7717f62
--- /dev/null
+++ b/src/db/zhi-textbook-content-schema.ts
@@ -0,0 +1,160 @@
+/**
+ * ZHI 路 鏁欐潗绔犺妭姝ｆ枃搴擄紙璇炬枃 / 渚嬮 / 涔犻锛夛紝涓庣洰褰曞厓鏁版嵁鍒嗙
+ */
+
+import { createHash, randomUUID } from 'crypto';
+import { getLearningDb } from '../../server/wuxian-learning-db';
+
+export type TextbookExercise = {
+  id: string;
+  prompt: string;
+  answer: string;
+  type: 'choice' | 'fill_blank' | 'short';
+  options?: string[];
+  knowledgePoint?: string;
+};
+
+export type TextbookChapterContentRow = {
+  id: string;
+  catalog_id: string;
+  chapter_index: number;
+  chapter_title: string;
+  reading_text: string;
+  examples_json: string;
+  exercises_json: string;
+  source_kind: string;
+  enrichment_status: string;
+  content_hash: string;
+  created_at: number;
+  updated_at: number;
+};
+
+export function initializeZhiTextbookContentSchema(): void {
+  getLearningDb().exec(`
+    CREATE TABLE IF NOT EXISTS zhi_textbook_chapter_content (
+      id TEXT PRIMARY KEY,
+      catalog_id TEXT NOT NULL,
+      chapter_index INTEGER NOT NULL,
+      chapter_title TEXT NOT NULL,
+      reading_text TEXT NOT NULL DEFAULT '',
+      examples_json TEXT NOT NULL DEFAULT '[]',
+      exercises_json TEXT NOT NULL DEFAULT '[]',
+      source_kind TEXT NOT NULL DEFAULT 'seed',
+      enrichment_status TEXT NOT NULL DEFAULT 'pending',
+      content_hash TEXT NOT NULL,
+      created_at INTEGER DEFAULT (strftime('%s', 'now')),
+      updated_at INTEGER DEFAULT (strftime('%s', 'now'))
+    );
+    CREATE UNIQUE INDEX IF NOT EXISTS idx_textbook_content_chapter
+      ON zhi_textbook_chapter_content(catalog_id, chapter_index);
+    CREATE INDEX IF NOT EXISTS idx_textbook_content_status
+      ON zhi_textbook_chapter_content(enrichment_status, catalog_id);
+  `);
+}
+
+function contentHash(reading: string, examples: string, exercises: string): string {
+  return createHash('sha256').update(`${reading}::${examples}::${exercises}`).digest('hex').slice(0, 40);
+}
+
+export function upsertTextbookChapterContent(input: {
+  catalogId: string;
+  chapterIndex: number;
+  chapterTitle: string;
+  readingText: string;
+  examples?: Array<{ title: string; body: string }>;
+  exercises?: TextbookExercise[];
+  sourceKind?: string;
+  enrichmentStatus?: 'enriched' | 'pending';
+}): TextbookChapterContentRow {
+  initializeZhiTextbookContentSchema();
+  const examplesJson = JSON.stringify(input.examples ?? []);
+  const exercisesJson = JSON.stringify(input.exercises ?? []);
+  const hash = contentHash(input.readingText, examplesJson, exercisesJson);
+  const existing = getLearningDb()
+    .prepare(
+      `SELECT id FROM zhi_textbook_chapter_content WHERE catalog_id = ? AND chapter_index = ?`,
+    )
+    .get(input.catalogId, input.chapterIndex) as { id: string } | undefined;
+  const id = existing?.id ?? randomUUID();
+
+  getLearningDb()
+    .prepare(
+      `
+    INSERT INTO zhi_textbook_chapter_content (
+      id, catalog_id, chapter_index, chapter_title, reading_text,
+      examples_json, exercises_json, source_kind, enrichment_status, content_hash, updated_at
+    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, strftime('%s', 'now'))
+    ON CONFLICT(catalog_id, chapter_index) DO UPDATE SET
+      chapter_title = excluded.chapter_title,
+      reading_text = excluded.reading_text,
+      examples_json = excluded.examples_json,
+      exercises_json = excluded.exercises_json,
+      source_kind = excluded.source_kind,
+      enrichment_status = excluded.enrichment_status,
+      content_hash = excluded.content_hash,
+      updated_at = excluded.updated_at
+  `,
+    )
+    .run(
+      id,
+      input.catalogId,
+      input.chapterIndex,
+      input.chapterTitle.slice(0, 120),
+      input.readingText.slice(0, 12000),
+      examplesJson,
+      exercisesJson,
+      input.sourceKind?.slice(0, 24) ?? 'seed',
+      input.enrichmentStatus ?? 'enriched',
+      hash,
+    );
+
+  return getChapterContent(input.catalogId, input.chapterIndex)!;
+}
+
+export function getChapterContent(
+  catalogId: string,
+  chapterIndex: number,
+): TextbookChapterContentRow | null {
+  initializeZhiTextbookContentSchema();
+  const row = getLearningDb()
+    .prepare(
+      `SELECT * FROM zhi_textbook_chapter_content WHERE catalog_id = ? AND chapter_index = ?`,
+    )
+    .get(catalogId, chapterIndex) as TextbookChapterContentRow | undefined;
+  return row ?? null;
+}
+
+export function listEnrichedChapterContent(catalogId: string): TextbookChapterContentRow[] {
+  initializeZhiTextbookContentSchema();
+  return getLearningDb()
+    .prepare(
+      `SELECT * FROM zhi_textbook_chapter_content
+       WHERE catalog_id = ? AND enrichment_status = 'enriched'
+       ORDER BY chapter_index ASC`,
+    )
+    .all(catalogId) as TextbookChapterContentRow[];
+}
+
+export function parseChapterContent(row: TextbookChapterContentRow): {
+  readingText: string;
+  examples: Array<{ title: string; body: string }>;
+  exercises: TextbookExercise[];
+} {
+  let examples: Array<{ title: string; body: string }> = [];
+  let exercises: TextbookExercise[] = [];
+  try {
+    examples = JSON.parse(row.examples_json) as Array<{ title: string; body: string }>;
+  } catch {
+    examples = [];
+  }
+  try {
+    exercises = JSON.parse(row.exercises_json) as TextbookExercise[];
+  } catch {
+    exercises = [];
+  }
+  return {
+    readingText: row.reading_text,
+    examples,
+    exercises,
+  };
+}
