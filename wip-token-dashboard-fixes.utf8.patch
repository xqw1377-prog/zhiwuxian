+    index[`${kp.subjectId}::${normKey(s)}`] = kp;
+  }
+}
+
+export function canonicalizeKnowledgePointLabel(subjectId: string, label: string): string | null {
+  const key = `${subjectId}::${normKey(label)}`;
+  const hit = index[key];
+  return hit ? hit.name : null;
+}
+
+export function findKnowledgePoint(subjectId: string, labelOrId: string): KnowledgePointEntry | null {
+  const key = `${subjectId}::${normKey(labelOrId)}`;
+  const hit = index[key];
+  return hit ?? null;
+}
+
+export function listKnowledgePointsForSubject(subjectId: string): KnowledgePointEntry[] {
+  const sid = subjectId.trim();
+  return REGISTRY.filter((kp) => kp.subjectId === sid);
+}
+
+export function getNextKnowledgePointsInTrack(
+  subjectId: string,
+  currentLabelOrId: string,
+  skipCount = 1,
+): { next: KnowledgePointEntry; skipped: KnowledgePointEntry[] } | null {
+  const list = listKnowledgePointsForSubject(subjectId);
+  if (!list.length) return null;
+
+  const current = findKnowledgePoint(subjectId, currentLabelOrId);
+  const currentIdx = current ? list.findIndex((kp) => kp.id === current.id) : -1;
+  const startIdx = currentIdx >= 0 ? currentIdx + 1 : 0;
+  const safeSkip = Math.max(0, Math.floor(skipCount));
+  const skipped = list.slice(startIdx, startIdx + safeSkip);
+  const nextIdx = Math.min(list.length - 1, startIdx + safeSkip);
+  return { next: list[nextIdx]!, skipped };
+}
+
+export function canonicalizeKnowledgePoints<T extends { id?: string; name?: string }>(
+  subjectId: string,
+  points: T[],
+): CanonicalizeResult<T & { id: string; name: string }> {
+  const out: Array<T & { id: string; name: string }> = [];
+  const unknown: string[] = [];
+  const seen = new Set<string>();
+
+  for (const p of points ?? []) {
+    const rawName = String(p?.name ?? '').trim();
+    const rawId = String(p?.id ?? '').trim();
+    const byName = rawName ? index[`${subjectId}::${normKey(rawName)}`] : undefined;
+    const byId = rawId ? index[`${subjectId}::${normKey(rawId)}`] : undefined;
+    const hit = byName ?? byId;
+    if (!hit) {
+      if (rawName) unknown.push(rawName.slice(0, 80));
+      continue;
+    }
+    if (seen.has(hit.id)) continue;
+    seen.add(hit.id);
+    out.push({ ...(p as T), id: hit.id, name: hit.name });
+  }
+
+  return { canonical: out, unknown: [...new Set(unknown)].slice(0, 40) };
+}
+
+export function shouldMarkEnriched(input: {
+  canonicalCount: number;
+  unknownCount: number;
+  minCanonical?: number;
+  minRatio?: number;
+}): boolean {
+  const canonical = Math.max(0, input.canonicalCount);
+  const unknown = Math.max(0, input.unknownCount);
+  const minCanonical = Math.max(1, input.minCanonical ?? 3);
+  const minRatio = Math.max(0, Math.min(1, input.minRatio ?? 0.6));
+  const total = canonical + unknown;
+  if (canonical < minCanonical) return false;
+  if (total <= 0) return false;
+  return canonical / total >= minRatio;
+}
