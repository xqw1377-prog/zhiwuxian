--- /dev/null
+++ b/scripts/seed-textbook-content.ts
@@ -0,0 +1,96 @@
+/**
+ * 灏?data/textbook-content/*.json 鍏ュ簱鍒?zhi_textbook_chapter_content
+ * 鎸変功鍚?鍑虹増绀惧尮閰嶇敤鎴锋暀鏉愮洰褰曪紙鍙栫涓€鏈尮閰嶏級
+ *
+ * npm run seed:textbook-content
+ */
+
+import { readFileSync, readdirSync } from 'fs';
+import { join } from 'path';
+import { loadEnvFiles } from '../server/load-env';
+
+loadEnvFiles();
+
+type SeedFile = {
+  matchTitle: string;
+  matchPublisher: string;
+  subject?: string;
+  chapters: Array<{
+    chapterIndex: number;
+    chapterTitle: string;
+    readingText: string;
+    examples?: Array<{ title: string; body: string }>;
+    exercises?: Array<{
+      id: string;
+      type: string;
+      prompt: string;
+      answer: string;
+      options?: string[];
+      knowledgePoint?: string;
+    }>;
+  }>;
+};
+
+async function main() {
+  const { initializeZhiTextbookCatalogSchema } = await import('../src/db/zhi-textbook-catalog-schema');
+  const { initializeZhiTextbookContentSchema, upsertTextbookChapterContent } = await import(
+    '../src/db/zhi-textbook-content-schema'
+  );
+  const { getLearningDb } = await import('../server/wuxian-learning-db');
+
+  initializeZhiTextbookCatalogSchema();
+  initializeZhiTextbookContentSchema();
+
+  const dir = join(process.cwd(), 'data', 'textbook-content');
+  const files = readdirSync(dir).filter((f) => f.endsWith('.json'));
+  let total = 0;
+
+  for (const file of files) {
+    const raw = JSON.parse(readFileSync(join(dir, file), 'utf8')) as SeedFile;
+    const catalogs = getLearningDb()
+      .prepare(
+        `SELECT id, title FROM zhi_textbook_catalog
+         WHERE title LIKE ? AND publisher LIKE ? LIMIT 5`,
+      )
+      .all(`%${raw.matchTitle.slice(0, 8)}%`, `%${raw.matchPublisher.slice(0, 4)}%`) as Array<{
+      id: string;
+      title: string;
+    }>;
+
+    if (!catalogs.length) {
+      console.log(`  鈯?${file}锛氭湭鎵惧埌鍖归厤鏁欐潗鐩綍锛?{raw.matchTitle} / ${raw.matchPublisher}锛夛紝璺宠繃`);
+      continue;
+    }
+
+    for (const cat of catalogs) {
+      for (const ch of raw.chapters) {
+        upsertTextbookChapterContent({
+          catalogId: cat.id,
+          chapterIndex: ch.chapterIndex,
+          chapterTitle: ch.chapterTitle,
+          readingText: ch.readingText,
+          examples: ch.examples,
+          exercises: ch.exercises?.map((e) => ({
+            id: e.id,
+            prompt: e.prompt,
+            answer: e.answer,
+            type: (e.type as 'choice' | 'fill_blank' | 'short') ?? 'choice',
+            options: e.options,
+            knowledgePoint: e.knowledgePoint,
+          })),
+          sourceKind: `seed:${file}`,
+          enrichmentStatus: 'enriched',
+        });
+        total += 1;
+        console.log(`  鉁?${cat.title} 路 绗?{ch.chapterIndex}绔燻);
+      }
+    }
+  }
+
+  console.log(`\n瀹屾垚锛氬啓鍏?${total} 涓珷鑺傛鏂囧潡`);
+}
+
+main().catch((e) => {
+  console.error(e);
+  process.exit(1);
+});
