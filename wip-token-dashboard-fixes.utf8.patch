+/**
+ * ZHI 路 鎸夋爣绛句粠鍏叡棰樺簱鎶介缁勫嵎
+ */
+
+import {
+  listEnrichedQuestionsForSubject,
+  rowToAssessmentQuestion,
+  type QuestionBankRow,
+} from '../db/zhi-question-bank-schema';
+import type { AssessmentQuestion } from '../db/zhi-assessment-schema';
+import { canonicalSubjectId, subjectIdsEquivalent } from './subject-id-resolver';
+import type { CurriculumTrack } from './learner-profile';
+
+export type PickQuestionsFromBankInput = {
+  subjectId: string;
+  knowledgePoints?: string[];
+  weakPoints?: string[];
+  gradeBand?: string;
+  curriculumTrack?: CurriculumTrack | 'undetermined';
+  provinceOrRegion?: string | null;
+  count: number;
+  /** 棰樺瀷鍋忓ソ锛堥粯璁ゆ贩鍚堬級 */
+  preferTypes?: Array<AssessmentQuestion['type']>;
+};
+
+function normalizeTag(s: string): string {
+  return s.trim().toLowerCase().replace(/\s+/g, '');
+}
+
+function tagOverlap(a: string, b: string): boolean {
+  const na = normalizeTag(a);
+  const nb = normalizeTag(b);
+  if (!na || !nb) return false;
+  return na.includes(nb) || nb.includes(na);
+}
+
+function scoreQuestion(
+  row: QuestionBankRow,
+  input: PickQuestionsFromBankInput,
+): number {
+  const tags = (() => {
+    try {
+      return JSON.parse(row.topic_tags_json) as string[];
+    } catch {
+      return [];
+    }
+  })();
+
+  const needles = [
+    ...(input.knowledgePoints ?? []),
+    ...(input.weakPoints ?? []),
+  ].filter(Boolean);
+
+  let score = 10;
+  for (const n of needles) {
+    if (tagOverlap(row.knowledge_point, n)) score += 28;
+    for (const t of tags) {
+      if (tagOverlap(t, n)) score += 12;
+    }
+  }
+
+  if (input.gradeBand && row.grade_band) {
+    if (tagOverlap(row.grade_band, input.gradeBand) || row.grade_band === '閫氱敤') score += 12;
+  }
+  if (input.curriculumTrack && row.curriculum_track) {
+    if (row.curriculum_track === input.curriculumTrack || row.curriculum_track === 'undetermined') {
+      score += 10;
+    }
+  }
+  if (input.provinceOrRegion && row.province_or_region) {
+    if (tagOverlap(row.province_or_region, input.provinceOrRegion)) score += 8;
+  }
+
+  if (input.preferTypes?.length && input.preferTypes.includes(row.question_type as AssessmentQuestion['type'])) {
+    score += 6;
+  }
+
+  return score;
+}
+
+/** 浠?enriched 棰樺簱鎶介锛涗笉瓒?count 鏃惰繑鍥炲疄闄呮潯鏁?*/
+export function pickQuestionsFromBank(input: PickQuestionsFromBankInput): {
+  questions: AssessmentQuestion[];
+  picked: number;
+  available: number;
+} {
+  const subjectId = canonicalSubjectId(input.subjectId) || input.subjectId;
+  const pool = listEnrichedQuestionsForSubject(subjectId, 300);
+  const available = pool.length;
+  const want = Math.max(1, Math.min(40, Math.floor(input.count)));
+
+  if (!pool.length) {
+    return { questions: [], picked: 0, available: 0 };
+  }
+
+  const scored = pool
+    .map((row) => ({ row, score: scoreQuestion(row, input) }))
+    .sort((a, b) => b.score - a.score);
+
+  const usedKp = new Set<string>();
+  const out: AssessmentQuestion[] = [];
+
+  for (const { row } of scored) {
+    if (out.length >= want) break;
+    const kpKey = normalizeTag(row.knowledge_point);
+    if (kpKey && usedKp.has(kpKey) && out.length >= Math.min(4, want)) continue;
+    if (kpKey) usedKp.add(kpKey);
+    out.push(rowToAssessmentQuestion(row, out.length));
+  }
+
+  return { questions: out, picked: out.length, available };
+}
+
+export function bankHasMinimumForSubject(subjectId: string, min = 4): boolean {
+  const canon = canonicalSubjectId(subjectId) || subjectId;
+  const pool = listEnrichedQuestionsForSubject(canon, 50);
+  return pool.filter((r) => subjectIdsEquivalent(r.subject_id, canon)).length >= min;
+}
