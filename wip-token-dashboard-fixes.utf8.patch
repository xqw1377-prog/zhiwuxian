@@ -0,0 +1,75 @@
+/**
+ * B 绔欏閾炬挱鏀惧櫒锛氬涔犲満鏅粯璁ゅ叧闂脊骞曪紙璇勮椋樺睆锛夊苟灏介噺鍏抽棴瀛楀箷
+ * @see https://player.bilibili.com/
+ */
+
+export type BilibiliEmbedOpts = {
+  /** 鍒?P锛屼粠 1 寮€濮?*/
+  page?: number;
+  /** 璧峰绉掓暟 */
+  startSec?: number;
+};
+
+/** 浠?B 绔欓〉闈?URL 瑙ｆ瀽 BV銆乸銆乼 */
+export function parseBilibiliPageUrl(url: string): {
+  bvid: string | null;
+  page: number;
+  startSec: number;
+} {
+  const bvid = url.match(/bilibili\.com\/video\/(BV[\w]+)/i)?.[1] ?? null;
+  let page = 1;
+  let startSec = 0;
+  try {
+    const u = new URL(url.startsWith('http') ? url : `https://${url}`);
+    const p = Number(u.searchParams.get('p'));
+    if (Number.isFinite(p) && p >= 1) page = Math.floor(p);
+    const tRaw = u.searchParams.get('t') ?? u.searchParams.get('start_progress');
+    if (tRaw) {
+      const t = Number(tRaw);
+      if (Number.isFinite(t) && t >= 0) startSec = Math.floor(t);
+    }
+  } catch {
+    /* ignore */
+  }
+  return { bvid, page, startSec };
+}
+
+/** 绔欏鎾斁鍣?URL锛堝畼鏂?player.html锛岄粯璁ゅ叧寮瑰箷锛?*/
+export function buildBilibiliEmbedUrl(bvid: string, opts?: BilibiliEmbedOpts): string {
+  const params = new URLSearchParams();
+  params.set('bvid', bvid);
+  params.set('high_quality', '1');
+  params.set('isOutside', 'true');
+  params.set('danmaku', '0');
+  params.set('autoplay', '0');
+  if (opts?.page && opts.page > 1) params.set('p', String(opts.page));
+  if (opts?.startSec && opts.startSec > 0) params.set('t', String(Math.floor(opts.startSec)));
+  return `https://player.bilibili.com/player.html?${params.toString()}`;
+}
+
+const BILI_ORIGINS = [
+  'https://player.bilibili.com',
+  'https://www.bilibili.com',
+  'https://m.bilibili.com',
+];
+
+/** iframe 鍔犺浇鍚庡皾璇曞叧闂瓧骞曪紙鏃犲畼鏂?query 鍙傛暟鏃剁殑琛ユ晳锛?*/
+export function postBilibiliDisableSubtitle(iframe: HTMLIFrameElement | null): void {
+  if (!iframe?.contentWindow) return;
+  const payloads: unknown[] = [
+    { type: 'setSubtitle', value: { show: false } },
+    { type: 'subtitle', data: { show: false, open: false } },
+    { command: 'subtitle', data: { show: false } },
+    { event: 'subtitle', action: 'hide' },
+  ];
+  for (const origin of BILI_ORIGINS) {
+    for (const payload of payloads) {
+      try {
+        iframe.contentWindow.postMessage(payload, origin);
+        iframe.contentWindow.postMessage(JSON.stringify(payload), origin);
+      } catch {
+        /* cross-origin */
+      }
+    }
+  }
+}
