@@ -0,0 +1,81 @@
+import http from 'k6/http';
+import { check, sleep, group } from 'k6';
+import { Rate, Trend } from 'k6/metrics';
+
+const TOKEN = __ENV.TOKEN || '';
+const BASE_URL = __ENV.BASE_URL || 'http://localhost:3400';
+
+const errorRate = new Rate('errors');
+const walletLatency = new Trend('wallet_latency_ms');
+const userLatency = new Trend('user_latency_ms');
+const adminLatency = new Trend('admin_latency_ms');
+
+const AUTH_HEADERS = {
+  'Content-Type': 'application/json',
+  'Authorization': `Bearer ${TOKEN}`,
+};
+
+export const options = {
+  stages: [
+    { duration: '30s', target: 10 },
+    { duration: '1m', target: 30 },
+    { duration: '30s', target: 0 },
+  ],
+  thresholds: {
+    errors: ['rate<0.10'],
+    wallet_latency_ms: ['p(95)<2000'],
+    user_latency_ms: ['p(95)<2000'],
+    admin_latency_ms: ['p(95)<5000'],
+    http_req_failed: ['rate<0.05'],
+  },
+};
+
+export default function () {
+  group('Wallet API', () => {
+    for (const endpoint of [
+      '/api/v1/wallet/balance',
+      '/api/v1/wallet/transactions?limit=5',
+    ]) {
+      const res = http.get(`${BASE_URL}${endpoint}`, { headers: AUTH_HEADERS });
+      walletLatency.add(res.timings.duration);
+      check(res, {
+        [`wallet ${endpoint} 200`]: () => res.status === 200,
+      });
+    }
+
+    sleep(Math.random() * 0.5 + 0.1);
+  });
+
+  group('User API', () => {
+    for (const endpoint of [
+      '/api/v1/user/profile',
+      '/api/v1/user/stats',
+      '/api/v1/user/settings',
+    ]) {
+      const res = http.get(`${BASE_URL}${endpoint}`, { headers: AUTH_HEADERS });
+      userLatency.add(res.timings.duration);
+      check(res, {
+        [`user ${endpoint} 200`]: () => res.status === 200,
+      });
+    }
+
+    sleep(Math.random() * 0.5 + 0.2);
+  });
+
+  if (Math.random() > 0.8 && TOKEN) {
+    group('Admin API', () => {
+      for (const endpoint of [
+        '/api/v1/admin/users?limit=10',
+        '/api/v1/admin/system/health',
+      ]) {
+        const res = http.get(`${BASE_URL}${endpoint}`, { headers: AUTH_HEADERS });
+        adminLatency.add(res.timings.duration);
+        check(res, {
+          [`admin ${endpoint} 200`]: () => res.status === 200,
+        });
+      }
+    });
+  }
+
+  sleep(Math.random() * 1.5 + 0.5);
+}
