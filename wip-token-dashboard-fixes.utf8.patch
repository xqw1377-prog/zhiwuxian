diff --git a/web/src/components/progress/ZhiTodayPanel.tsx b/web/src/components/progress/ZhiTodayPanel.tsx
new file mode 100644
index 0000000..ea86f11
--- /dev/null
+++ b/web/src/components/progress/ZhiTodayPanel.tsx
@@ -0,0 +1,247 @@
+import { useEffect, useMemo, useState } from 'react';
+import { useLearningProgress } from '../../context/LearningProgressContext';
+import { useZhiChat } from '../../context/ZhiChatContext';
+import type { DailyReviewDto } from '../../lib/zhi-daily-review-api';
+import { emitWuxianEventUntyped, onWuxianEventUntyped, WUXIAN_EVENTS } from '../../lib/wuxian-events';
+import { ensureAuthSession } from '../../lib/api-auth';
+import { generateAssessmentPaper } from '../../lib/zhi-assessment-api';
+import { fetchCoursewareMatches } from '../../lib/video-learn-api';
+
+type TodayMode = 'assessment' | 'video' | 'path';
+
+function formatTime(ts: number): string {
+  const d = new Date(ts);
+  return `${d.getMonth() + 1}/${d.getDate()} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
+}
+
+function normalizeSubjectId(id: string): string {
+  const s = String(id ?? '').trim();
+  if (s === 'phys') return 'physics';
+  if (s === 'chem') return 'chemistry';
+  if (s === 'en') return 'english';
+  return s || 'math';
+}
+
+export function ZhiTodayPanel() {
+  const { dashboard, loading } = useLearningProgress();
+  const { openTool, userId } = useZhiChat();
+  const [mode, setMode] = useState<TodayMode>('assessment');
+  const [dailyReview, setDailyReview] = useState<DailyReviewDto | null>(null);
+  const [busy, setBusy] = useState(false);
+  const [err, setErr] = useState('');
+
+  useEffect(() => {
+    return onWuxianEventUntyped(WUXIAN_EVENTS.dailyReview, (detail) => {
+      const d = detail as DailyReviewDto | undefined;
+      if (d?.reviewDate) setDailyReview(d);
+    });
+  }, []);
+
+  const weakest = useMemo(() => {
+    const list = [...(dashboard?.subjects ?? [])];
+    list.sort((a, b) => a.progressPct - b.progressPct);
+    return list[0] ?? null;
+  }, [dashboard?.subjects]);
+
+  const p0 = useMemo(() => {
+    const list = dailyReview?.planCorrections ?? [];
+    const hit = list.find((x) => x.priority === 'P0') ?? null;
+    return hit
+      ? {
+          subjectId: normalizeSubjectId(hit.subjectId),
+          subjectName: hit.subjectName,
+          action: hit.action,
+        }
+      : null;
+  }, [dailyReview?.planCorrections]);
+
+  const focusSubjectId = p0?.subjectId ?? weakest?.id ?? null;
+  const focusSubjectName = p0?.subjectName ?? weakest?.name ?? '';
+
+  const kpHint = useMemo(() => {
+    if (!focusSubjectId) return '';
+    const tb =
+      (dashboard?.textbooks ?? []).find((t) => t.subject === focusSubjectId) ?? (dashboard?.textbooks ?? [])[0];
+    const kp = tb?.knowledgePoints?.[0]?.trim() ?? '';
+    return kp.slice(0, 24);
+  }, [dashboard?.textbooks, focusSubjectId]);
+
+  const primaryLine = p0
+    ? p0.action
+    : focusSubjectId
+      ? `鍏堟妸銆?{focusSubjectName}${kpHint ? ` 路 ${kpHint}` : ''}銆嶈ˉ鍒拌兘杩囬獙鏀禶
+      : '鎴戣繕娌℃嬁鍒颁綘鐨勫涔犺瘉鎹?;
+
+  const primaryCta = () => {
+    if (!focusSubjectId) {
+      openTool('vision-intercept', { launch: { visionTab: 'photo' } });
+      return;
+    }
+    if (mode === 'assessment') {
+      void (async () => {
+        setErr('');
+        setBusy(true);
+        try {
+          await ensureAuthSession(userId);
+          const paper = await generateAssessmentPaper(userId, {
+            subjectId: focusSubjectId,
+            adaptive: true,
+            userHint: p0?.action ? `P0:${p0.action}` : `TODAY:${focusSubjectId}`,
+          });
+          openTool('learning-assessment', {
+            silent: true,
+            launch: { assessmentTab: 'subject', assessmentSubjectId: focusSubjectId, assessmentPaperId: paper.id },
+          });
+        } catch (e) {
+          const msg = e instanceof Error ? e.message : String(e ?? '鍑哄嵎澶辫触');
+          setErr(msg);
+          openTool('learning-assessment', {
+            silent: true,
+            launch: { assessmentTab: 'subject', assessmentSubjectId: focusSubjectId },
+          });
+        } finally {
+          setBusy(false);
+        }
+      })();
+      return;
+    }
+    if (mode === 'video') {
+      void (async () => {
+        setErr('');
+        setBusy(true);
+        try {
+          await ensureAuthSession(userId);
+          const pack = await fetchCoursewareMatches(userId);
+          const best =
+            pack?.matches?.find((m) => m.courseware.subject === focusSubjectId)?.courseware ??
+            pack?.matches?.[0]?.courseware ??
+            null;
+          openTool('video-learn', { silent: true });
+          if (best?.sourceUrl) {
+            emitWuxianEventUntyped(WUXIAN_EVENTS.videoLearnStart, {
+              sourceUrl: best.sourceUrl,
+              title: best.title,
+            });
+          }
+        } catch (e) {
+          const msg = e instanceof Error ? e.message : String(e ?? '鎵撳紑瑙嗛澶辫触');
+          setErr(msg);
+          openTool('video-learn', { silent: true });
+        } finally {
+          setBusy(false);
+        }
+      })();
+      return;
+    }
+    openTool('learning-path', { silent: true });
+  };
+
+  const secondaryCta = () => {
+    if (!focusSubjectId) {
+      openTool('learning-assessment', { launch: { assessmentTab: 'daily' } });
+      return;
+    }
+    const next: TodayMode = mode === 'assessment' ? 'video' : mode === 'video' ? 'path' : 'assessment';
+    setMode(next);
+    if (next === 'assessment')
+      openTool('learning-assessment', {
+        launch: { assessmentTab: 'subject', assessmentSubjectId: focusSubjectId },
+      });
+    if (next === 'video') openTool('video-learn', { silent: true });
+    if (next === 'path') openTool('learning-path', { silent: true });
+  };
+
+  const outcomes = (dashboard?.outcomes ?? []).slice(0, 3);
+
+  return (
+    <div className="space-y-3">
+      <div className="rounded-xl border border-[color:var(--zhi-accent-border)] bg-[color:var(--zhi-accent-soft)] p-3">
+        <div className="flex items-center justify-between gap-2">
+          <div className="text-[10px] font-black tracking-widest text-[color:rgb(var(--zhi-accent-rgb))]">浠婃棩蹇呭仛</div>
+          <div className="text-[11px] text-[color:var(--zhi-text-3)]">{busy ? '鐢熸垚涓€? : loading ? '鍚屾涓€? : ''}</div>
+        </div>
+        <p className="mt-2 text-[11px] leading-relaxed text-[color:var(--zhi-text)]">{primaryLine}</p>
+        {err && (
+          <p className="mt-2 rounded-lg border border-amber-500/20 bg-amber-500/5 px-2 py-1 text-[10px] text-amber-700">
+            {err}
+          </p>
+        )}
+        <div className="mt-3 flex gap-2">
+          <button
+            type="button"
+            onClick={primaryCta}
+            disabled={busy}
+            className="flex-1 rounded-lg bg-[color:rgb(var(--zhi-accent-rgb))] py-2 text-[10px] font-black text-black hover:opacity-90 disabled:opacity-60"
+          >
+            {focusSubjectId ? '绔嬪嵆寮€濮? : '鍘绘媿鐓у缓妗?}
+          </button>
+          <button
+            type="button"
+            onClick={secondaryCta}
+            disabled={busy}
+            className="rounded-lg border border-[color:var(--zhi-border)] bg-[color:var(--zhi-panel-bg)] px-3 py-2 text-[10px] text-[color:var(--zhi-text-2)] hover:border-[color:var(--zhi-accent-border)]"
+          >
+            {focusSubjectId ? '鎹竴绉嶆柟寮? : '鍏堝仛璇勪及'}
+          </button>
+        </div>
+      </div>
+
+      {focusSubjectId && (
+        <div className="rounded-xl border border-[color:var(--zhi-border)] bg-[color:var(--zhi-panel-bg)] p-3">
+          <div className="flex items-center justify-between">
+            <p className="text-[10px] font-black tracking-widest text-[color:var(--zhi-text)]">褰撳墠鐭澘</p>
+            <span className="text-[11px] text-[color:var(--zhi-text-3)]">{focusSubjectName || focusSubjectId}</span>
+          </div>
+          <p className="mt-1 text-[10px] text-[color:var(--zhi-text-3)]">{kpHint ? `浼樺厛锛?{kpHint}` : '浼樺厛锛氳ˉ榻愬熀纭€涓庨獙鏀?}</p>
+          <div className="mt-2 flex gap-2">
+            <button
+              type="button"
+              onClick={() =>
+                openTool('learning-assessment', {
+                  launch: { assessmentTab: 'subject', assessmentSubjectId: focusSubjectId },
+                })
+              }
+              className="flex-1 rounded-lg border border-violet-500/35 py-2 text-[10px] text-violet-700 hover:bg-violet-500/10"
+            >
+              鍑轰竴濂楃煭鏉垮嵎
+            </button>
+            <button
+              type="button"
+              onClick={() => openTool('video-learn', { silent: true })}
+              className="flex-1 rounded-lg border border-amber-500/35 py-2 text-[10px] text-amber-700 hover:bg-amber-500/10"
+            >
+              鐪嬭瑙ｈ棰?+            </button>
+          </div>
+        </div>
+      )}
+
+      <div className="rounded-xl border border-[color:var(--zhi-border)] bg-[color:var(--zhi-panel-bg)] p-3">
+        <p className="text-[10px] font-black tracking-widest text-[color:var(--zhi-text)]">鏈€杩戞垚鏋?/p>
+        {outcomes.length === 0 ? (
+          <p className="mt-2 text-[10px] leading-relaxed text-[color:var(--zhi-text-3)]">
+            鍏堝畬鎴愪竴娆¤瘎浼版垨涓婁紶涓€寮犺瘯鍗凤紝鎴戜細鎶婂彲楠岃瘉鎴愭灉鍐欒繘杩欓噷銆?+          </p>
+        ) : (
+          <ul className="mt-2 space-y-2">
+            {outcomes.map((o) => (
+              <li key={o.id}>
+                <button
+                  type="button"
+                  onClick={() => openTool('learning-path', { silent: true })}
+                  className="w-full rounded-lg border border-[color:var(--zhi-border)] bg-[color:var(--zhi-surface-bg)] px-2 py-2 text-left hover:border-[color:var(--zhi-accent-border)]"
+                >
+                  <p className="truncate text-[10px] font-medium text-[color:var(--zhi-text)]">{o.title}</p>
+                  <p className="mt-1 flex items-center justify-between gap-2 text-[11px] text-[color:var(--zhi-text-3)]">
+                    <span className="truncate">{o.source}</span>
+                    <span className="shrink-0 font-mono">{formatTime(o.at)}</span>
+                  </p>
+                </button>
+              </li>
+            ))}
+          </ul>
+        )}
+      </div>
+    </div>
+  );
+}
