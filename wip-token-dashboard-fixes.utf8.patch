+          subjectLabel: SUBJECT_ZH[focus] ?? focus,
+          enrichedInCatalog: statsAll.enriched,
+          pendingInSubject: statsSubject.pending,
+        })
+      : null;
+
+  return { matches, libraryGap };
+}
