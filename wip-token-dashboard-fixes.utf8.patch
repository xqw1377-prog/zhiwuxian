new file mode 100644
index 0000000..dc79932
--- /dev/null
+++ b/server/graceful-shutdown.ts
@@ -0,0 +1,38 @@
+import { shutdownOpenTelemetry } from './telemetry-otel';
+import { detectDbEngine, getCoreEngine, getLearningEngine } from './db';
+
+let shuttingDown = false;
+
+export function handleShutdown(): void {
+  process.on('SIGINT', async () => {
+    if (shuttingDown) return;
+    shuttingDown = true;
+    console.log('\n[Shutdown] 鏀跺埌 SIGINT锛屽紑濮嬩紭闆呭叧闂?..');
+
+    try {
+      await shutdownOpenTelemetry();
+      if (detectDbEngine() === 'postgresql') {
+        await getCoreEngine().close();
+        await getLearningEngine().close();
+        console.log('[Shutdown] PostgreSQL 杩炴帴姹犲凡鍏抽棴');
+      }
+    } catch (err) {
+      console.error('[Shutdown] 鍏抽棴杩囩▼鍑洪敊:', err);
+    }
+
+    console.log('[Shutdown] 鏈嶅姟宸插仠姝?);
+    process.exit(0);
+  });
+
+  process.on('SIGTERM', () => {
+    if (shuttingDown) return;
+    shuttingDown = true;
+    console.log('\n[Shutdown] 鏀跺埌 SIGTERM锛岄€€鍑轰腑...');
+    process.exit(0);
+  });
+
+  process.on('uncaughtException', (err) => {
+    console.error('[Fatal] 鏈崟鑾峰紓甯?', err);
+    process.exit(1);
+  });
+}
