+/**
+ * ZHI 路 璧勬簮搴撻鏍囨敞锛氬叆搴撳墠/鎵归噺 AI 璇勪及鐭ヨ瘑鐐逛笌鏍囩
+ */
+
+import type { SecondaryAssessmentReport } from '../../engine/core/video-assimilation-brain';
+import {
+  getCoursewareById,
+  getCoursewareBySourceUrl,
+  listCoursewareNeedingEnrichment,
+  upsertCourseware,
+  type CoursewareCatalogInput,
+} from '../db/zhi-courseware-catalog-schema';
+import { getSchoolAnchorProfile } from '../db/zhi-cloud-schema';
+import { buildLearnerProfile, type CurriculumTrack } from './learner-profile';
+import { gatewayJsonCompletion } from './llm-gateway';
+import { normalizeTagProfile, tagFingerprint, type ResourceTagProfile } from './resource-tag-profile';
+import { coursewareSubjectFromRequest } from './subject-id-resolver';
+import {
+  canonicalizeKnowledgePoints,
+  shouldMarkEnriched,
+} from './knowledge-point-registry';
+
+const ENRICH_SYSTEM = `浣犳槸 ZHI 璧勬簮鏍囨敞瀹樸€傛牴鎹棰?璇句欢鍏冧俊鎭紝杈撳嚭缁撴瀯鍖栨爣绛?JSON锛屼緵銆屾寜骞寸骇+鐭ヨ瘑鐐广€嶇簿鍑嗗尮閰嶃€?+鍙緭鍑?JSON锛?+{
+  "subjectId": "math|physics|english|toefl|sat|algo|cs|essay",
+  "gradeBand": "濡傦細楂樹竴/楂樹簩/楂樹笁/鍒濅笁/閫氱敤",
+  "curriculumTrack": "cn_gaokao|intl_ib_ap|intl_us_uk|k12_stage|undetermined",
+  "provinceOrRegion": "濡傦細婀栧崡 鎴?null",
+  "topicTags": ["鏍囩1","鏍囩2"],
+  "knowledgePoints": [{"id":"kp1","name":"鐭ヨ瘑鐐瑰悕","chapterHint":"绔犺妭"}],
+  "examAlign": ["鏂伴珮鑰?,"TOEFL"],
+  "difficulty": "B1|B2|B3|A2",
+  "audience": ["high_school"],
+  "summary": "20瀛楀唴璇存槑閫傜敤浜虹兢涓庡唴瀹?
+}
+瑙勫垯锛氱煡璇嗙偣蹇呴』鍏蜂綋鍙獙鏀讹紱subjectId 涓庡唴瀹逛竴鑷达紱鍥藉唴楂樹腑鐢?cn_gaokao銆俙;
+
+export type EnrichCoursewareResult = {
+  ok: boolean;
+  coursewareId: string;
+  profile?: ResourceTagProfile;
+  reason: string;
+};
+
+export function profileFromReport(
+  report: SecondaryAssessmentReport,
+  title: string,
+  subjectHint?: string,
+): ResourceTagProfile {
+  const text = `${report.primaryCategory} ${report.subCategory} ${title}`;
+  let subjectId = 'math';
+  if (/鐗╃悊|physics/i.test(text)) subjectId = 'physics';
+  else if (/鑻辫|鎵樼|toefl/i.test(text)) subjectId = 'toefl';
+  else if (/鍖栧/i.test(text)) subjectId = 'chemistry';
+  else if (/绠楁硶|usaco/i.test(text)) subjectId = 'algo';
+  if (subjectHint) subjectId = coursewareSubjectFromRequest(subjectHint);
+
+  const normalized = normalizeTagProfile({
+    subjectId,
+    gradeBand: /楂樹笁|楂樿€?.test(text) ? '楂樹笁' : /楂樹簩/.test(text) ? '楂樹簩' : /楂樹竴/.test(text) ? '楂樹竴' : '閫氱敤',
+    curriculumTrack: /鎵樼|sat|ap|ib|a-level/i.test(text) ? 'intl_us_uk' : 'cn_gaokao',
+    provinceOrRegion: text.match(/(婀栧崡|鍖椾含|涓婃捣|骞夸笢|娴欐睙|姹熻嫃)/)?.[1] ?? null,
+    topicTags: report.knowledgeCells.map((c) => c.name).slice(0, 12),
+    knowledgePoints: report.knowledgeCells.map((c) => ({
+      id: c.id,
+      name: c.name,
+      chapterHint: report.subCategory,
+    })),
+    examAlign: subjectId === 'toefl' ? ['TOEFL'] : subjectId === 'math' ? ['鏂伴珮鑰兟锋暟瀛?] : [],
+    difficulty: 'B2',
+    audience: ['high_school'],
+    summary: `${report.primaryCategory} 路 ${report.knowledgeCells.length} 涓煡璇嗙墖娈礰,
+  });
+  const canon = canonicalizeKnowledgePoints(normalized.subjectId, normalized.knowledgePoints);
+  return normalizeTagProfile({
+    ...normalized,
+    topicTags: [...new Set([...normalized.topicTags, ...canon.canonical.map((k) => k.name)])],
+    knowledgePoints: canon.canonical,
+  });
+}
+
+async function llmEnrichProfile(input: {
+  userId: string;
+  title: string;
+  platform: string;
+  sourceUrl: string;
+  subjectHint?: string;
+  cellsSummary?: string;
+  anchorSchool?: string;
+  anchorGrade?: string;
+}): Promise<ResourceTagProfile | null> {
+  const uid = input.userId.trim() || 'system-enrich';
+  const userPayload = [
+    `鏍囬锛?{input.title}`,
+    `骞冲彴锛?{input.platform}`,
+    `閾炬帴锛?{input.sourceUrl}`,
+    input.subjectHint ? `瀛︾鎻愮ず锛?{input.subjectHint}` : '',
+    input.cellsSummary ? `鐭ヨ瘑鐗囨锛歕n${input.cellsSummary}` : '',
+    input.anchorSchool ? `姊︽牎锛?{input.anchorSchool}` : '',
+    input.anchorGrade ? `骞寸骇锛?{input.anchorGrade}` : '',
+  ]
+    .filter(Boolean)
+    .join('\n');
+
+  const gw = await gatewayJsonCompletion<ResourceTagProfile>(uid, [
+    { role: 'system', content: ENRICH_SYSTEM },
+    { role: 'user', content: userPayload },
+  ], {
+    traceId: `resource_enrich_${Date.now()}`,
+    maxTokens: 900,
+    temperature: 0.2,
+  });
+
+  if (!gw.chargeOk || !gw.data) return null;
+  const normalized = normalizeTagProfile(gw.data);
+  const canon = canonicalizeKnowledgePoints(normalized.subjectId, normalized.knowledgePoints);
+  return normalizeTagProfile({
+    ...normalized,
+    topicTags: [...new Set([...normalized.topicTags, ...canon.canonical.map((k) => k.name)])],
+    knowledgePoints: canon.canonical,
+  });
+}
+
+export function applyTagProfileToCoursewareInput(
+  base: CoursewareCatalogInput,
+  profile: ResourceTagProfile,
+): CoursewareCatalogInput {
+  return {
+    ...base,
+    subject: coursewareSubjectFromRequest(profile.subjectId),
+    difficulty: profile.difficulty ?? base.difficulty,
+    topicTags: [...new Set([...base.topicTags, ...profile.topicTags])].slice(0, 24),
+    knowledgePoints: profile.knowledgePoints.map((k) => ({
+      id: k.id,
+      name: k.name,
+      chapterHint: k.chapterHint,
+      timestampSec: base.knowledgePoints.find((x) => x.id === k.id || x.name === k.name)?.timestampSec,
+    })),
+    examAlign: [...new Set([...(base.examAlign ?? []), ...profile.examAlign])],
+    audience: profile.audience,
+    summary: profile.summary || base.summary,
+  };
+}
+
+export function rowEnrichmentFields(profile: ResourceTagProfile, enrichmentStatus: 'enriched' | 'pending' | 'failed') {
+  return {
+    gradeBand: profile.gradeBand,
+    curriculumTrack: profile.curriculumTrack,
+    provinceOrRegion: profile.provinceOrRegion,
+    enrichmentStatus,
+    enrichmentVersion: 1,
+    tagFingerprint: tagFingerprint(profile),
+  };
+}
+
+/** 瀵瑰凡鍏ュ簱鏉＄洰琛ュ厖/鍒锋柊 AI 鏍囩 */
+export async function enrichCoursewareById(
+  coursewareId: string,
+  opts?: { userId?: string; report?: SecondaryAssessmentReport },
+): Promise<EnrichCoursewareResult> {
+  const row = getCoursewareById(coursewareId);
+  if (!row) return { ok: false, coursewareId, reason: '璇句欢涓嶅瓨鍦? };
+
+  const uid = opts?.userId?.trim() || 'system-enrich';
+  const anchor = getSchoolAnchorProfile(uid);
+  const learner = buildLearnerProfile(uid);
+
+  let profile: ResourceTagProfile | null = null;
+  if (opts?.report) {
+    profile = profileFromReport(opts.report, row.title, row.subject);
+  } else {
+    const cells = JSON.parse(row.knowledge_points_json) as Array<{ name: string }>;
+    profile = await llmEnrichProfile({
+      userId: uid,
+      title: row.title,
+      platform: row.platform,
+      sourceUrl: row.source_url,
+      subjectHint: row.subject,
+      cellsSummary: cells.map((c) => `- ${c.name}`).join('\n'),
+      anchorSchool: anchor?.school,
+      anchorGrade: anchor?.currentGrade ?? learner?.gradeBand,
+    });
+  }
+
+  if (!profile) {
+    profile = normalizeTagProfile({
+      subjectId: row.subject,
+      gradeBand: anchor?.currentGrade ?? learner?.gradeBand ?? '閫氱敤',
+      curriculumTrack: (learner?.curriculumTrack ?? 'undetermined') as CurriculumTrack,
+      provinceOrRegion: learner?.provinceOrRegion ?? null,
+      topicTags: JSON.parse(row.topic_tags_json) as string[],
+      knowledgePoints: JSON.parse(row.knowledge_points_json) as ResourceTagProfile['knowledgePoints'],
+      examAlign: JSON.parse(row.exam_align_json) as string[],
+      difficulty: row.difficulty,
+      audience: JSON.parse(row.audience_json) as string[],
+      summary: row.summary ?? row.title,
+    });
+  }
+  const canon = canonicalizeKnowledgePoints(profile.subjectId, profile.knowledgePoints);
+  profile = normalizeTagProfile({
+    ...profile,
+    topicTags: [...new Set([...profile.topicTags, ...canon.canonical.map((k) => k.name)])],
+    knowledgePoints: canon.canonical,
+  });
+  const ok = shouldMarkEnriched({
+    canonicalCount: canon.canonical.length,
+    unknownCount: canon.unknown.length,
+    minCanonical: 3,
+    minRatio: 0.6,
+  });
+  const status: 'enriched' | 'pending' = ok ? 'enriched' : 'pending';
+
+  const baseInput: CoursewareCatalogInput = {
+    title: row.title,
+    instructor: row.instructor ?? undefined,
+    platform: row.platform,
+    sourceUrl: row.source_url,
+    durationMin: row.duration_min ?? undefined,
+    subject: row.subject,
+    difficulty: row.difficulty ?? undefined,
+    qualityGrade: row.quality_grade as CoursewareCatalogInput['qualityGrade'],
+    logicScore: row.logic_score,
+    intuitionScore: row.intuition_score,
+    rigorScore: row.rigor_score,
+    productionScore: row.production_score,
+    completenessScore: row.completeness_score,
+    topicTags: JSON.parse(row.topic_tags_json),
+    knowledgePoints: JSON.parse(row.knowledge_points_json),
+    schoolAlign: JSON.parse(row.school_align_json),
+    examAlign: JSON.parse(row.exam_align_json),
+    audience: JSON.parse(row.audience_json),
+    wormholeValue: row.wormhole_value,
+    recommendedSec: row.recommended_sec,
+    summary: row.summary ?? undefined,
+    ...rowEnrichmentFields(profile, status),
+  };
+
+  const merged = applyTagProfileToCoursewareInput(baseInput, profile);
+  upsertCourseware(merged);
+
+  return {
+    ok,
+    coursewareId: row.id,
+    profile,
+    reason: ok
+      ? `宸叉爣娉?${profile.knowledgePoints.length} 涓煡璇嗙偣 路 ${profile.gradeBand} 路 ${profile.curriculumTrack}`
+      : `鏍囩缃俊搴︿笉瓒筹細宸插綊涓€鍖?${profile.knowledgePoints.length} 涓煡璇嗙偣锛涜琛ュ厖绉嶅瓙鐭ヨ瘑鐐硅〃鎴栦汉宸ュ鏍稿悗閲嶈瘯`,
+  };
+}
+
+export function listCoursewareIdsNeedingEnrichment(limit = 50): string[] {
+  return listCoursewareNeedingEnrichment(limit).map((r) => r.id);
+}
+
+export async function enrichCoursewareByUrl(
+  sourceUrl: string,
+  opts?: { userId?: string; report?: SecondaryAssessmentReport },
+): Promise<EnrichCoursewareResult> {
+  const row = getCoursewareBySourceUrl(sourceUrl.trim());
+  if (!row) return { ok: false, coursewareId: '', reason: '閾炬帴鏈叆搴擄紝璇峰厛鍚屽寲鎴栧鍏? };
+  return enrichCoursewareById(row.id, opts);
+}
