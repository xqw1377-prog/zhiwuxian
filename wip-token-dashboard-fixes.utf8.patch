+    duration_min: 20,
+    subject: partial.subject,
+    difficulty: null,
+    quality_grade: partial.quality_grade ?? 'S',
+    logic_score: 0.9,
+    intuition_score: 0.85,
+    rigor_score: 0.8,
+    production_score: 0.75,
+    completeness_score: 0.8,
+    topic_tags_json: JSON.stringify(['鍑芥暟', '瀵兼暟']),
+    knowledge_points_json: JSON.stringify([{ id: 'kp1', name: '鍑芥暟' }]),
+    school_align_json: '[]',
+    exam_align_json: '[]',
+    audience_json: '["high_school"]',
+    wormhole_value: 0.8,
+    recommended_sec: 0,
+    summary: null,
+    status: 'active',
+    grade_band: 'g11',
+    curriculum_track: null,
+    province_or_region: null,
+    enrichment_status: partial.enrichment_status,
+    enrichment_version: partial.enrichment_status === 'enriched' ? 1 : 0,
+    tag_fingerprint: null,
+    created_at: 1,
+    updated_at: 1,
+  };
+}
+
+describe('buildCoursewareLibraryGapMessage', () => {
+  it('鍏ㄥ簱鏃?enriched 鏃惰繑鍥?no_enriched', () => {
+    const gap = buildCoursewareLibraryGapMessage({
+      enrichedInCatalog: 0,
+      pendingInSubject: 3,
+    });
+    expect(gap.code).toBe('no_enriched');
+    expect(gap.message).toContain('enrich:resources');
+  });
+
+  it('瀛︾鍐呮湁 pending 鏃?enriched 鏃舵彁绀哄緟鏍囨敞鏁伴噺', () => {
+    const gap = buildCoursewareLibraryGapMessage({
+      subjectLabel: '鏁板',
+      enrichedInCatalog: 5,
+      pendingInSubject: 2,
+    });
+    expect(gap.code).toBe('no_enriched_in_subject');
+    expect(gap.message).toContain('2 鏉?);
+    expect(gap.message).toContain('鏁板');
+  });
+});
+
+describe('matchCoursewareForSubject enriched-only', () => {
+  beforeEach(() => {
+    vi.mocked(listActiveCourseware).mockReset();
+  });
+
+  it('浠呰繑鍥?enriched 璇句欢', () => {
+    vi.mocked(listActiveCourseware).mockReturnValue([
+      mockCatalogRow({ id: 'pending-math', subject: 'math', enrichment_status: 'pending' }),
+      mockCatalogRow({ id: 'enriched-math', subject: 'math', enrichment_status: 'enriched', title: '宸叉爣娉ㄦ暟瀛﹁' }),
+      mockCatalogRow({ id: 'enriched-phys', subject: 'physics', enrichment_status: 'enriched', title: '鐗╃悊璇? }),
+    ]);
+
+    const { matches, libraryGap } = matchCoursewareForSubject('u-test', 'math', { limit: 6 });
+    expect(matches.length).toBeGreaterThan(0);
+    expect(matches.every((m) => m.courseware.subject === 'math')).toBe(true);
+    expect(matches[0]?.courseware.title).toBe('宸叉爣娉ㄦ暟瀛﹁');
+    expect(libraryGap).toBeNull();
+  });
+
+  it('浠呮湁 pending 鏃?matches 涓虹┖骞跺甫 libraryGap', () => {
+    vi.mocked(listActiveCourseware).mockReturnValue([
+      mockCatalogRow({ id: 'p1', subject: 'math', enrichment_status: 'pending' }),
+      mockCatalogRow({ id: 'p2', subject: 'math', enrichment_status: 'pending' }),
+    ]);
+
+    const { matches, libraryGap } = matchCoursewareForSubject('u-test', 'math', { limit: 6 });
+    expect(matches).toHaveLength(0);
+    expect(libraryGap).not.toBeNull();
+    expect(libraryGap?.code).toBe('no_enriched');
+    expect(libraryGap?.pendingInSubject).toBe(2);
+  });
+
+  it('涓嶆妸 S 绾?pending 褰撲綔 fallback 鎺ㄨ崘', () => {
+    vi.mocked(listActiveCourseware).mockReturnValue([
+      mockCatalogRow({
