diff --git a/src/db/zhi-question-bank-schema.ts b/src/db/zhi-question-bank-schema.ts
new file mode 100644
index 0000000..2d1b6af
--- /dev/null
+++ b/src/db/zhi-question-bank-schema.ts
@@ -0,0 +1,237 @@
+/**
+ * ZHI 路 鍏叡棰樺簱锛堟寜瀛︾/骞寸骇/鐭ヨ瘑鐐规爣绛炬娊棰樼粍鍗凤級
+ */
+
+import { createHash, randomUUID } from 'crypto';
+import { getLearningDb } from '../../server/wuxian-learning-db';
+import type { AssessmentQuestion, AssessmentQuestionType } from './zhi-assessment-schema';
+import { canonicalSubjectId, subjectIdsEquivalent } from '../services/subject-id-resolver';
+import { canonicalizeKnowledgePointLabel } from '../services/knowledge-point-registry';
+
+export type QuestionBankRow = {
+  id: string;
+  subject_id: string;
+  grade_band: string | null;
+  curriculum_track: string | null;
+  province_or_region: string | null;
+  knowledge_point: string;
+  topic_tags_json: string;
+  question_type: string;
+  prompt: string;
+  options_json: string | null;
+  correct_answer: string | null;
+  coach_follow_up: string | null;
+  difficulty: string | null;
+  enrichment_status: string | null;
+  source: string | null;
+  status: string;
+  prompt_fingerprint: string;
+  created_at: number;
+  updated_at: number;
+};
+
+export type QuestionBankInput = {
+  subjectId: string;
+  gradeBand?: string;
+  curriculumTrack?: string;
+  provinceOrRegion?: string | null;
+  knowledgePoint: string;
+  topicTags?: string[];
+  questionType: AssessmentQuestionType;
+  prompt: string;
+  options?: string[];
+  correctAnswer?: string;
+  coachFollowUp?: string;
+  difficulty?: string;
+  enrichmentStatus?: 'enriched' | 'pending';
+  source?: string;
+};
+
+function promptFingerprint(prompt: string): string {
+  return createHash('sha256').update(prompt.trim()).digest('hex').slice(0, 40);
+}
+
+function questionBankColumnExists(column: string): boolean {
+  const cols = getLearningDb()
+    .prepare(`PRAGMA table_info(zhi_question_bank)`)
+    .all() as Array<{ name: string }>;
+  return cols.some((c) => c.name === column);
+}
+
+export function initializeZhiQuestionBankSchema(): void {
+  getLearningDb().exec(`
+    CREATE TABLE IF NOT EXISTS zhi_question_bank (
+      id TEXT PRIMARY KEY,
+      subject_id TEXT NOT NULL,
+      grade_band TEXT,
+      curriculum_track TEXT,
+      province_or_region TEXT,
+      knowledge_point TEXT NOT NULL DEFAULT '',
+      topic_tags_json TEXT NOT NULL DEFAULT '[]',
+      question_type TEXT NOT NULL DEFAULT 'choice',
+      prompt TEXT NOT NULL,
+      options_json TEXT,
+      correct_answer TEXT,
+      coach_follow_up TEXT,
+      difficulty TEXT,
+      enrichment_status TEXT NOT NULL DEFAULT 'pending',
+      source TEXT,
+      status TEXT NOT NULL DEFAULT 'active',
+      prompt_fingerprint TEXT NOT NULL,
+      created_at INTEGER DEFAULT (strftime('%s', 'now')),
+      updated_at INTEGER DEFAULT (strftime('%s', 'now'))
+    );
+    CREATE UNIQUE INDEX IF NOT EXISTS idx_question_bank_fingerprint
+      ON zhi_question_bank(prompt_fingerprint);
+    CREATE INDEX IF NOT EXISTS idx_question_bank_subject_tags
+      ON zhi_question_bank(subject_id, enrichment_status, status);
+  `);
+}
+
+export function upsertQuestionBankItem(input: QuestionBankInput): QuestionBankRow {
+  initializeZhiQuestionBankSchema();
+  const subjectId = canonicalSubjectId(input.subjectId) || input.subjectId;
+  const canonKp = canonicalizeKnowledgePointLabel(subjectId, input.knowledgePoint) ?? input.knowledgePoint;
+  const knowledgePoint = (canonKp || '缁煎悎').trim().slice(0, 80) || '缁煎悎';
+  const fp = promptFingerprint(input.prompt);
+  const existing = getLearningDb()
+    .prepare(`SELECT id FROM zhi_question_bank WHERE prompt_fingerprint = ?`)
+    .get(fp) as { id: string } | undefined;
+  const id = existing?.id ?? randomUUID();
+
+  getLearningDb()
+    .prepare(
+      `
+    INSERT INTO zhi_question_bank (
+      id, subject_id, grade_band, curriculum_track, province_or_region,
+      knowledge_point, topic_tags_json, question_type, prompt, options_json,
+      correct_answer, coach_follow_up, difficulty, enrichment_status, source, status,
+      prompt_fingerprint, updated_at
+    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 'active', ?, strftime('%s', 'now'))
+    ON CONFLICT(prompt_fingerprint) DO UPDATE SET
+      subject_id = excluded.subject_id,
+      grade_band = excluded.grade_band,
+      curriculum_track = excluded.curriculum_track,
+      province_or_region = excluded.province_or_region,
+      knowledge_point = excluded.knowledge_point,
+      topic_tags_json = excluded.topic_tags_json,
+      question_type = excluded.question_type,
+      options_json = excluded.options_json,
+      correct_answer = excluded.correct_answer,
+      coach_follow_up = excluded.coach_follow_up,
+      difficulty = excluded.difficulty,
+      enrichment_status = excluded.enrichment_status,
+      source = excluded.source,
+      updated_at = excluded.updated_at
+  `,
+    )
+    .run(
+      id,
+      subjectId,
+      input.gradeBand?.slice(0, 24) ?? null,
+      input.curriculumTrack?.slice(0, 32) ?? null,
+      input.provinceOrRegion?.slice(0, 24) ?? null,
+      knowledgePoint,
+      JSON.stringify(
+        [...new Set([...(input.topicTags ?? []), knowledgePoint])].filter(Boolean).slice(0, 16),
+      ),
+      input.questionType,
+      input.prompt.slice(0, 700),
+      input.options ? JSON.stringify(input.options.slice(0, 6)) : null,
+      input.correctAnswer?.slice(0, 120) ?? null,
+      input.coachFollowUp?.slice(0, 200) ?? null,
+      input.difficulty?.slice(0, 16) ?? null,
+      input.enrichmentStatus ?? 'enriched',
+      input.source?.slice(0, 40) ?? 'seed',
+      fp,
+    );
+
+  return getQuestionBankById(id)!;
+}
+
+export function getQuestionBankById(id: string): QuestionBankRow | null {
+  initializeZhiQuestionBankSchema();
+  const row = getLearningDb()
+    .prepare(`SELECT * FROM zhi_question_bank WHERE id = ?`)
+    .get(id) as QuestionBankRow | undefined;
+  return row ?? null;
+}
+
+export function listEnrichedQuestionsForSubject(subjectId: string, limit = 200): QuestionBankRow[] {
+  initializeZhiQuestionBankSchema();
+  const canon = canonicalSubjectId(subjectId) || subjectId;
+  const n = Math.min(500, Math.max(1, limit));
+  const rows = getLearningDb()
+    .prepare(
+      `SELECT * FROM zhi_question_bank
+       WHERE status = 'active' AND enrichment_status = 'enriched'
+       ORDER BY updated_at DESC
+       LIMIT ?`,
+    )
+    .all(n) as QuestionBankRow[];
+  return rows.filter((r) => subjectIdsEquivalent(r.subject_id, canon));
+}
+
+export function rowToAssessmentQuestion(row: QuestionBankRow, index: number): AssessmentQuestion {
+  let options: string[] | undefined;
+  if (row.options_json) {
+    try {
+      const parsed = JSON.parse(row.options_json) as unknown;
+      if (Array.isArray(parsed)) options = parsed.map(String).slice(0, 6);
+    } catch {
+      options = undefined;
+    }
+  }
+  const type = String(row.question_type) as AssessmentQuestionType;
+  return {
+    id: `bank-${row.id.slice(0, 8)}-${index + 1}`,
+    prompt: row.prompt,
+    type: ['choice', 'short', 'speaking_hint', 'fill_blank', 'active_qa'].includes(type)
+      ? type
+      : 'choice',
+    options,
+    knowledgePoint: row.knowledge_point || undefined,
+    coachFollowUp: row.coach_follow_up ?? undefined,
+  };
+}
+
+export function ingestAssessmentQuestionsToBank(
+  questions: AssessmentQuestion[],
+  meta: {
+    subjectId: string;
+    gradeBand?: string;
+    curriculumTrack?: string;
+    provinceOrRegion?: string | null;
+    source?: string;
+  },
+): number {
+  let n = 0;
+  for (const q of questions) {
+    if (!q.prompt?.trim()) continue;
+    const canonSubject = canonicalSubjectId(meta.subjectId) || meta.subjectId;
+    const label =
+      canonicalizeKnowledgePointLabel(canonSubject, q.knowledgePoint ?? '') ?? q.knowledgePoint ?? '缁煎悎';
+    upsertQuestionBankItem({
+      subjectId: meta.subjectId,
+      gradeBand: meta.gradeBand,
+      curriculumTrack: meta.curriculumTrack,
+      provinceOrRegion: meta.provinceOrRegion,
+      knowledgePoint: label,
+      topicTags: label ? [label] : [],
+      questionType: q.type,
+      prompt: q.prompt,
+      options: q.options,
+      coachFollowUp: q.coachFollowUp,
+      enrichmentStatus: 'enriched',
+      source: meta.source ?? 'paper_ingest',
+    });
+    n += 1;
+  }
+  return n;
+}
+
+/** 閬垮厤璇敤 textbookColumnExists 鍚嶇О 鈥?浠呴搴撹〃 */
+export function questionBankTableReady(): boolean {
+  initializeZhiQuestionBankSchema();
+  return questionBankColumnExists('subject_id');
+}
