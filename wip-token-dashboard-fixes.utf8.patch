+/** 鏃堕棿鎰熺煡闂€欒 */
+export function zhTimeGreeting(): string {
+  const h = new Date().getHours();
+  if (h < 5) return '澶滄繁浜嗭紝杩樺湪涓烘ⅵ鏍″姫鍔涳紵';
+  if (h < 8) return '鏃╀笂濂斤紝鍙堟槸鏂扮殑涓€澶╋紝鍑嗗濂戒簡鍚楋紵';
+  if (h < 12) return '涓婂崍濂斤紝浠婂ぉ杩涘害鎬庝箞鏍凤紵';
+  if (h < 14) return '涓崍濂斤紝璁板緱浼戞伅銆?;
+  if (h < 18) return '涓嬪崍濂斤紝浠婂ぉ鏈変粈涔堟敹鑾凤紵';
+  if (h < 22) return '鏅氫笂浜嗭紝浠婂ぉ鍗″湪鍝紵';
+  return '杩樹笉鐫★紵浠婂ぉ鏈変粈涔堟兂璺熸垜鑱婅亰鐨勶紵';
