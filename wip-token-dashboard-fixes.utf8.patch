+import { getLearningDb } from '../../server/wuxian-learning-db';
+import { processReview, getDueItems, getItemStats, estimateMasteryDate } from './spaced-repetition';
+import type { ReviewItem, ReviewResult } from './spaced-repetition';
+
+export interface SpacedReviewRow {
+  id: string;
+  user_id: string;
+  subject: string;
+  content: string;
+  source_type: string;
+  source_id: string;
+  ease_factor: number;
+  interval_days: number;
+  repetitions: number;
+  next_review_at: string;
+  last_reviewed_at: string | null;
+  created_at: string;
+}
+
+export function recordReviewResult(userId: string, result: ReviewResult): void {
+  getLearningDb().prepare(`
+    UPDATE zhi_spaced_review
+    SET ease_factor = ?, interval_days = ?, repetitions = ?,
+        next_review_at = ?, last_reviewed_at = datetime('now'),
+        updated_at = datetime('now')
+    WHERE id = ?
+  `).run(result.newEaseFactor, result.newInterval, result.newRepetitions,
+    result.nextReviewAt, result.itemId);
+}
+
+export function addToSpacedReview(input: {
+  userId: string;
+  subject: string;
+  content: string;
+  sourceType: string;
+  sourceId: string;
+}): string {
+  const id = crypto.randomUUID();
+  const today = new Date().toISOString().split('T')[0];
+  getLearningDb().prepare(`
+    INSERT OR IGNORE INTO zhi_spaced_review (id, user_id, subject, content, source_type, source_id, ease_factor, interval_days, repetitions, next_review_at, created_at)
+    VALUES (?, ?, ?, ?, ?, ?, 2.5, 1, 0, ?, datetime('now'))
+  `).run(id, input.userId, input.subject, input.content, input.sourceType, input.sourceId, today);
+  return id;
+}
+
+export function getDueReviews(userId: string, limit = 20): SpacedReviewRow[] {
+  const today = new Date().toISOString().split('T')[0];
+  return getLearningDb().prepare(`
+    SELECT * FROM zhi_spaced_review
+    WHERE user_id = ? AND next_review_at <= ?
+    ORDER BY next_review_at ASC
+    LIMIT ?
+  `).all(userId, today, limit) as SpacedReviewRow[];
+}
+
+export function getReviewStats(userId: string): {
+  total: number;
+  due: number;
+  mastered: number;
+  averageEaseFactor: number;
+} {
+  const rows = getLearningDb().prepare(`
+    SELECT ease_factor, repetitions FROM zhi_spaced_review WHERE user_id = ?
+  `).all(userId) as { ease_factor: number; repetitions: number }[];
+
+  const items: ReviewItem[] = rows.map((r, i) => ({
+    id: String(i),
+    userId,
+    subject: '',
+    content: '',
+    easeFactor: r.ease_factor,
+    interval: 0,
+    repetitions: r.repetitions,
+    nextReviewAt: '',
+    lastReviewedAt: null,
+  }));
+
+  return getItemStats(items);
+}
+
+/**
+ * 灏嗘娴嬮缁撴灉鍐欏叆闂撮殧閲嶅闃熷垪
+ * quality: 0-5 (0=瀹屽叏蹇樿, 5=杞绘澗绛斿)
+ */
+export function processCheckpointForReview(
+  userId: string,
+  reviewId: string,
+  quality: number,
+): ReviewResult | null {
+  const row = getLearningDb().prepare(`
+    SELECT * FROM zhi_spaced_review WHERE id = ? AND user_id = ?
+  `).get(reviewId, userId) as SpacedReviewRow | undefined;
+  if (!row) return null;
+
+  const item: ReviewItem = {
+    id: row.id,
+    userId: row.user_id,
+    subject: row.subject,
+    content: row.content,
+    easeFactor: row.ease_factor,
+    interval: row.interval_days,
+    repetitions: row.repetitions,
+    nextReviewAt: row.next_review_at,
+    lastReviewedAt: row.last_reviewed_at,
+  };
+
+  const result = processReview(item, quality);
+  recordReviewResult(userId, result);
+  return result;
+}
