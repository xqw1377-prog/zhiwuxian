+/**
+ * 鎸夊绉戣仛鍚堣矾寰?鐭澘/鏁欐潗鐭ヨ瘑鐐癸紝渚涘嚭鍗蜂笌瑙嗛鍖归厤鍏辩敤
+ */
+
+import { listTextbooksForUser, parseTextbookOutline } from '../db/zhi-textbook-catalog-schema';
+import { getLearningPath } from './learning-path-engine';
+import { aggregateLearnerEvidence } from './learner-evidence-hub';
+import { inferSubjectIdFromTextbookLabel, subjectIdsEquivalent } from './subject-id-resolver';
+
+export function collectKnowledgePointsForSubject(
+  userId: string,
+  subjectId: string,
+): Array<{ title: string; source: string }> {
+  const out: Array<{ title: string; source: string }> = [];
+  const path = getLearningPath(userId);
+  if (path) {
+    for (const p of path.phases) {
+      for (const u of p.knowledgeUnits) {
+        if (subjectIdsEquivalent(u.subjectId, subjectId)) {
+          out.push({ title: u.title, source: `璺緞路${p.phase}` });
+        }
+      }
+    }
+  }
+  const evidence = aggregateLearnerEvidence(userId);
+  for (const w of evidence.weaknesses) {
+    if (subjectIdsEquivalent(w.subjectId, subjectId)) {
+      out.push({ title: w.title, source: '鐭澘璇佹嵁' });
+    }
+  }
+  for (const b of listTextbooksForUser(userId)) {
+    const subj = inferSubjectIdFromTextbookLabel(b.subject ?? b.title);
+    if (!subjectIdsEquivalent(subj, subjectId)) continue;
+    const ch = parseTextbookOutline(b).find((c) => c.index === (b.progress_chapter ?? 1));
+    for (const kp of (ch?.knowledgePoints ?? []).slice(0, 6)) {
+      out.push({ title: kp, source: b.title });
+    }
+  }
+  const seen = new Set<string>();
+  const deduped: typeof out = [];
+  for (const item of out) {
+    const key = item.title.slice(0, 48);
+    if (seen.has(key)) continue;
+    seen.add(key);
+    deduped.push(item);
+  }
+  return deduped.slice(0, 12);
+}
+
+export function formatSubjectContextBlock(userId: string, subjectId: string): string {
+  const points = collectKnowledgePointsForSubject(userId, subjectId);
+  if (!points.length) return '';
+  return points.map((p) => `- ${p.title}锛?{p.source}锛塦).join('\n');
+}
