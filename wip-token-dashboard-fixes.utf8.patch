+/**
+ * 鏁欐潗姝ｆ枃 鈫?璁叉巿/缁勫嵎浼樺厛浣跨敤搴撳唴鍐呭锛孡LM 浠呰ˉ鍏ㄦ垨璁茶В
+ */
+
+import {
+  getChapterContent,
+  listEnrichedChapterContent,
+  parseChapterContent,
+  upsertTextbookChapterContent,
+  type TextbookExercise,
+} from '../db/zhi-textbook-content-schema';
+import { getTextbookById } from '../db/zhi-textbook-catalog-schema';
+
+export type TeachingContentBundle = {
+  hasStoredContent: boolean;
+  chapterTitle: string;
+  readingText: string;
+  examplesBlock: string;
+  exercises: TextbookExercise[];
+  sourceKind: string;
+};
+
+export function resolveTeachingContent(
+  catalogId: string,
+  chapterIndex: number,
+): TeachingContentBundle {
+  const catalog = getTextbookById(catalogId);
+  const row = getChapterContent(catalogId, chapterIndex);
+  if (!row || row.enrichment_status !== 'enriched' || !row.reading_text.trim()) {
+    return {
+      hasStoredContent: false,
+      chapterTitle: row?.chapter_title ?? catalog ? `绗?{chapterIndex}绔燻 : `绗?{chapterIndex}绔燻,
+      readingText: '',
+      examplesBlock: '',
+      exercises: [],
+      sourceKind: 'llm_only',
+    };
+  }
+
+  const parsed = parseChapterContent(row);
+  const examplesBlock = parsed.examples
+    .map((e: { title: string; body: string }, i: number) => `銆愪緥棰?{i + 1}路${e.title}銆慭n${e.body}`)
+    .join('\n\n');
+
+  return {
+    hasStoredContent: true,
+    chapterTitle: row.chapter_title,
+    readingText: parsed.readingText,
+    examplesBlock,
+    exercises: parsed.exercises,
+    sourceKind: row.source_kind,
+  };
+}
+
+export function formatTeachingContentBlock(bundle: TeachingContentBundle): string {
+  if (!bundle.hasStoredContent) return '';
+  return [
+    '銆愭暀鏉愬簱鍐呮鏂?路 璇蜂互姝や负鍑嗚鎺堬紝鍕跨紪閫犱笌姝ｆ枃鐭涚浘鐨勫畾鐞嗐€?,
+    bundle.readingText.slice(0, 4000),
+    bundle.examplesBlock ? `\n銆愰厤濂椾緥棰樸€慭n${bundle.examplesBlock.slice(0, 2000)}` : '',
+    bundle.exercises.length
+      ? `\n銆愮珷鏈範棰?${bundle.exercises.length} 閬擄紝楠屾敹棰樹紭鍏堜粠涓娊鍙栥€慲
+      : '',
+  ]
+    .filter(Boolean)
+    .join('\n');
+}
+
+export function pickExerciseForCheckpoint(
+  exercises: TextbookExercise[],
+  knowledgePoint?: string,
+): TextbookExercise | null {
+  if (!exercises.length) return null;
+  const kp = knowledgePoint?.trim().toLowerCase();
+  if (kp) {
+    const hit = exercises.find(
+      (e) =>
+        e.knowledgePoint?.toLowerCase().includes(kp) ||
+        e.prompt.toLowerCase().includes(kp),
+    );
+    if (hit) return hit;
+  }
+  return exercises[0] ?? null;
+}
+
+export { upsertTextbookChapterContent, listEnrichedChapterContent };
