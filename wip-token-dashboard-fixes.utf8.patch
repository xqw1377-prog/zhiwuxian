+import { describe, expect, it, beforeEach } from 'vitest';
+import { resetLearningDbForTests } from '../server/wuxian-learning-db';
+import { initializeZhiQuestionBankSchema, upsertQuestionBankItem } from '../src/db/zhi-question-bank-schema';
+import { pickQuestionsFromBank, bankHasMinimumForSubject } from '../src/services/zhi-question-bank-picker';
+import { seedQuestionBank } from '../src/data/question-bank-seed';
+
+describe('zhi-question-bank-picker', () => {
+  beforeEach(() => {
+    resetLearningDbForTests();
+    initializeZhiQuestionBankSchema();
+    seedQuestionBank();
+  });
+
+  it('鎸夊绉戞娊棰樹笖浠?enriched', () => {
+    const { questions, picked, available } = pickQuestionsFromBank({
+      subjectId: 'math',
+      knowledgePoints: ['鍑芥暟鍗曡皟鎬?],
+      count: 4,
+    });
+    expect(available).toBeGreaterThanOrEqual(4);
+    expect(picked).toBe(4);
+    expect(questions.every((q) => q.prompt.length > 3)).toBe(true);
+    expect(questions.some((q) => /鍗曡皟|鍑芥暟|瀵兼暟/.test(q.knowledgePoint ?? q.prompt))).toBe(true);
+  });
+
+  it('pending 棰樹笉鍏ュ簱鎶介缁撴灉', () => {
+    upsertQuestionBankItem({
+      subjectId: 'math',
+      knowledgePoint: '涓嶅簲鍑虹幇',
+      questionType: 'choice',
+      prompt: '杩欐槸涓€閬撴湭鏍囨敞棰?UNIQUE_PENDING_XYZ',
+      options: ['A', 'B'],
+      enrichmentStatus: 'pending',
+    });
+    const { questions } = pickQuestionsFromBank({
+      subjectId: 'math',
+      count: 20,
+    });
+    expect(questions.every((q) => !q.prompt.includes('UNIQUE_PENDING_XYZ'))).toBe(true);
+  });
+
+  it('bankHasMinimumForSubject', () => {
+    expect(bankHasMinimumForSubject('math', 4)).toBe(true);
+    expect(bankHasMinimumForSubject('chemistry', 4)).toBe(false);
+  });
+});
