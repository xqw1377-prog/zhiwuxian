diff --git a/src/services/resource-tag-profile.ts b/src/services/resource-tag-profile.ts
new file mode 100644
index 0000000..e9f7c9a
--- /dev/null
+++ b/src/services/resource-tag-profile.ts
@@ -0,0 +1,106 @@
+/**
+ * 缁熶竴璧勬簮鏍囩鐢诲儚锛氳棰戣浠?/ 鏁欐潗绔犺妭 / 璇曞嵎棰樼洰 鍏辩敤瀛楁
+ */
+
+import type { CurriculumTrack } from './learner-profile';
+import { canonicalSubjectId } from './subject-id-resolver';
+
+export type ResourceTagProfile = {
+  subjectId: string;
+  gradeBand: string;
+  curriculumTrack: CurriculumTrack | 'undetermined';
+  provinceOrRegion: string | null;
+  topicTags: string[];
+  knowledgePoints: Array<{ id: string; name: string; chapterHint?: string }>;
+  examAlign: string[];
+  difficulty: string | null;
+  audience: string[];
+  summary: string;
+};
+
+export function normalizeTagProfile(raw: Partial<ResourceTagProfile>): ResourceTagProfile {
+  const subjectId = canonicalSubjectId(raw.subjectId ?? 'math') || 'math';
+  const track = raw.curriculumTrack ?? 'undetermined';
+  const gradeBand = String(raw.gradeBand ?? '閫氱敤').trim().slice(0, 24) || '閫氱敤';
+  const topicTags = [...new Set((raw.topicTags ?? []).map((t) => String(t).trim()).filter(Boolean))].slice(
+    0,
+    32,
+  );
+  const knowledgePoints = (raw.knowledgePoints ?? [])
+    .map((k, i) => ({
+      id: String(k.id ?? `kp-${i + 1}`).slice(0, 40),
+      name: String(k.name ?? '').trim().slice(0, 80),
+      chapterHint: k.chapterHint ? String(k.chapterHint).slice(0, 60) : undefined,
+    }))
+    .filter((k) => k.name.length > 0)
+    .slice(0, 40);
+
+  for (const kp of knowledgePoints) {
+    const tag = kp.name.slice(0, 24);
+    if (tag && !topicTags.includes(tag)) topicTags.push(tag);
+  }
+
+  return {
+    subjectId,
+    gradeBand,
+    curriculumTrack: track,
+    provinceOrRegion: raw.provinceOrRegion?.trim() || null,
+    topicTags,
+    knowledgePoints,
+    examAlign: [...new Set((raw.examAlign ?? []).map(String))].slice(0, 12),
+    difficulty: raw.difficulty?.trim() || null,
+    audience: [...new Set((raw.audience ?? ['high_school']).map(String))].slice(0, 8),
+    summary: String(raw.summary ?? '').trim().slice(0, 400),
+  };
+}
+
+export function tagFingerprint(profile: ResourceTagProfile): string {
+  const kp = profile.knowledgePoints
+    .map((k) => k.name)
+    .sort()
+    .join('|');
+  return [
+    profile.subjectId,
+    profile.gradeBand,
+    profile.curriculumTrack,
+    profile.provinceOrRegion ?? '',
+    kp.slice(0, 120),
+  ].join('::');
+}
+
+/** 瀛︿範鑰呯敾鍍忎笌璧勬簮鏍囩鏄惁鍚岃建锛堝勾绾?璇剧翰/鐪佷唤锛?*/
+export function tagProfileMatchesLearner(
+  resource: ResourceTagProfile,
+  learner: {
+    curriculumTrack: CurriculumTrack;
+    gradeBand: string;
+    provinceOrRegion: string | null;
+  },
+): { score: number; reasons: string[] } {
+  let score = 0;
+  const reasons: string[] = [];
+  if (resource.curriculumTrack === learner.curriculumTrack) {
+    score += 15;
+    reasons.push('璇剧▼杞ㄤ竴鑷?);
+  } else if (
+    resource.curriculumTrack === 'undetermined' ||
+    learner.curriculumTrack === 'undetermined'
+  ) {
+    score += 4;
+  }
+  const g1 = resource.gradeBand.replace(/\s/g, '');
+  const g2 = learner.gradeBand.replace(/\s/g, '');
+  if (g1 && g2 && (g1.includes(g2) || g2.includes(g1) || g1 === '閫氱敤' || g2 === '閫氱敤')) {
+    score += 12;
+    reasons.push(`骞寸骇 ${resource.gradeBand}`);
+  }
+  if (
+    resource.provinceOrRegion &&
+    learner.provinceOrRegion &&
+    resource.provinceOrRegion === learner.provinceOrRegion
+  ) {
+    score += 8;
+    reasons.push(`鐪佷唤 ${resource.provinceOrRegion}`);
+  }
+  return { score, reasons };
+}
diff --git a/src/services/subject-id-resolver.ts b/src/services/subject-id-resolver.ts
new file mode 100644
index 0000000..9cddce3
--- /dev/null
+++ b/src/services/subject-id-resolver.ts
@@ -0,0 +1,87 @@
+/**
+ * 缁熶竴瀵硅瘽/璇勪及 subjectId 涓庤繘搴︾湅鏉?subject id锛坧hysics vs phys锛?+ */
+
+const CANONICAL: Record<string, string> = {
+  phys: 'physics',
+  physics: 'physics',
+  chem: 'chemistry',
+  chemistry: 'chemistry',
+  en: 'english',
+  english: 'english',
+  chinese: 'chinese',
+  math: 'math',
+  toefl: 'toefl',
+  sat: 'sat',
+  ap: 'ap',
+  gpa: 'gpa',
+  gaokao: 'gaokao',
+  algo: 'algo',
+  essay: 'essay',
+  oi: 'oi',
+  comp: 'comp',
+  science: 'science',
+  rank: 'rank',
+};
+
+export function canonicalSubjectId(id: string | null | undefined): string {
+  const k = String(id ?? '').trim().toLowerCase();
+  if (!k) return '';
+  return CANONICAL[k] ?? k;
+}
+
+export function subjectIdsEquivalent(a: string | null | undefined, b: string | null | undefined): boolean {
+  const ca = canonicalSubjectId(a);
+  const cb = canonicalSubjectId(b);
+  if (!ca || !cb) return false;
+  return ca === cb;
+}
+
+/** 鍖归厤 dash.subjects[].id 鐨勫€欓€?id 鍒楄〃 */
+export function dashboardSubjectIdCandidates(requestId: string): string[] {
+  const raw = requestId.trim();
+  const canon = canonicalSubjectId(raw);
+  const set = new Set<string>([raw, canon]);
+  if (canon === 'physics') set.add('phys');
+  if (canon === 'english') set.add('en');
+  if (canon === 'chemistry') set.add('chem');
+  return [...set];
+}
+
+export function pickDashboardSubject<T extends { id: string }>(
+  subjects: T[],
+  requestId: string | null | undefined,
+): T | undefined {
+  if (!subjects.length) return undefined;
+  const candidates = requestId ? dashboardSubjectIdCandidates(requestId) : [];
+  for (const c of candidates) {
+    const hit = subjects.find((s) => s.id === c || subjectIdsEquivalent(s.id, c));
+    if (hit) return hit;
+  }
+  return subjects.find((s) => s.id === 'math') ?? subjects[0];
+}
+
+/** 璇句欢搴?subject 瀛楁锛坢ath / physics / toefl 鈥︼級 */
+export function coursewareSubjectFromRequest(requestId: string): string {
+  const canon = canonicalSubjectId(requestId);
+  if (canon === 'physics') return 'physics';
+  if (canon === 'chemistry') return 'chemistry';
+  if (canon === 'english') return 'english';
+  if (canon === 'toefl') return 'toefl';
+  if (canon === 'sat') return 'sat';
+  if (canon === 'algo') return 'algo';
+  if (canon === 'essay') return 'essay';
+  if (canon === 'math') return 'math';
+  return canon || 'math';
+}
+
+export function inferSubjectIdFromTextbookLabel(label: string): string {
+  const s = label.trim();
+  if (/鐗╃悊/.test(s)) return 'physics';
+  if (/鏁板/.test(s)) return 'math';
+  if (/鑻辫|鑻辨枃/.test(s)) return 'english';
+  if (/鍖栧/.test(s)) return 'chemistry';
+  if (/璇枃/.test(s)) return 'chinese';
+  if (/绉戝|缁煎悎/.test(s)) return 'science';
+  return 'math';
+}
