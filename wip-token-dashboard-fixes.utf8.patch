+  sampleCount: number;
+  /** 鎶樺彔鏁堢巼锛氭彁鍗囩櫨鍒嗙偣 / 瀛︿範灏忔椂锛堜笌 admin 鎸囨爣瀵归綈璇箟锛?*/
+  foldVelocity: number;
+  hint: string;
+};
+
+export function computeMasteryFold(userId: string, studyHours28d: number): MasteryFoldSnapshot {
+  const uid = userId.trim();
+  const rows = getLearningDb()
+    .prepare(
+      `
+    SELECT p.subject_id AS subject_id, a.score_pct, a.created_at
+    FROM zhi_assessment_attempts a
+    INNER JOIN zhi_assessment_papers p ON p.id = a.paper_id
+    WHERE a.user_id = ? AND a.score_pct IS NOT NULL
+      AND a.created_at >= strftime('%s', 'now', '-28 days')
+    ORDER BY p.subject_id ASC, a.created_at ASC
+    `,
+    )
+    .all(uid) as Array<{ subject_id: string; score_pct: number; created_at: number }>;
+
+  const bySubject = new Map<string, number[]>();
+  for (const r of rows) {
+    const list = bySubject.get(r.subject_id) ?? [];
+    list.push(Number(r.score_pct));
+    bySubject.set(r.subject_id, list);
+  }
+
+  const lifts: number[] = [];
+  for (const scores of bySubject.values()) {
+    if (scores.length < 2) continue;
+    const first = scores[0]!;
+    const last = scores[scores.length - 1]!;
+    lifts.push(last - first);
+  }
+
+  const avgLiftPct =
+    lifts.length > 0 ? Math.round((lifts.reduce((a, b) => a + b, 0) / lifts.length) * 10) / 10 : 0;
+  const hours = Math.max(0.5, studyHours28d);
+  const foldVelocity = Math.round((avgLiftPct / hours) * 100) / 100;
+
+  let hint = '瀹屾垚鑷冲皯涓ゆ鍚岀璇勪及鍚庯紝灏嗘樉绀烘帉鎻″害鎻愬崌锛堟姌鍙犻€熷害锛夈€?;
+  if (lifts.length >= 2) {
+    hint =
+      avgLiftPct > 0
+        ? `杩?28 澶╁悓绉戞帉鎻″害骞冲潎鎻愬崌 ${avgLiftPct} 鐧惧垎鐐癸紝鎶樺彔閫熷害 ${foldVelocity}锛堟彁鍗?灏忔椂锛夈€俙
+        : `杩?28 澶╂帉鎻″害鏆傛棤鍑€鎻愬崌锛屽缓璁厛澶嶄範閿欓鍐嶅嚭鏂板嵎銆俙;
+  } else if (lifts.length === 1) {
+    hint = `宸茶娴嬪埌 1 缁勫墠鍚庢祴锛屾彁鍗?${avgLiftPct} 鐧惧垎鐐癸紱鍐嶅鍋?1 娆￠獙鏀跺彲绋冲畾鎶樺彔鎸囨爣銆俙;
+  }
+
+  return {
+    avgLiftPct,
+    sampleCount: lifts.length,
+    foldVelocity,
+    hint,
+  };
+}
