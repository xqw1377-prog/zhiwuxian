@@ -0,0 +1,74 @@
+import http from 'k6/http';
+import { check, sleep, group } from 'k6';
+import { Rate, Trend } from 'k6/metrics';
+
+const TOKEN = __ENV.TOKEN || '';
+const BASE_URL = __ENV.BASE_URL || 'http://localhost:3400';
+
+const errorRate = new Rate('errors');
+const llmLatency = new Trend('llm_latency_ms');
+
+const LLM_PAYLOADS = [
+  { model: 'deepseek-chat', messages: [{ role: 'user', content: 'Hello' }], max_tokens: 50, temperature: 0.7 },
+  { model: 'deepseek-chat', messages: [{ role: 'user', content: 'Explain AI in 3 sentences' }], max_tokens: 100, temperature: 0.5 },
+  { model: 'deepseek-chat', messages: [{ role: 'user', content: 'What is the capital of France?' }], max_tokens: 50, temperature: 0.3 },
+];
+
+const HEADERS_WITH_FLATWARP = {
+  'Content-Type': 'application/json',
+  'Authorization': `Bearer ${TOKEN}`,
+  'X-FlatWarp': '300',
+};
+
+const HEADERS_WITHOUT_FLATWARP = {
+  'Content-Type': 'application/json',
+  'Authorization': `Bearer ${TOKEN}`,
+};
+
+export const options = {
+  stages: [
+    { duration: '30s', target: 10 },
+    { duration: '1m', target: 50 },
+    { duration: '30s', target: 100 },
+    { duration: '1m', target: 100 },
+    { duration: '30s', target: 0 },
+  ],
+  thresholds: {
+    errors: ['rate<0.10'],
+    llm_latency_ms: ['p(95)<30000'],
+    http_req_duration: ['p(95)<5000'],
+    http_req_failed: ['rate<0.05'],
+  },
+};
+
+export default function () {
+  const payload = LLM_PAYLOADS[Math.floor(Math.random() * LLM_PAYLOADS.length)];
+  const useFlatWarp = Math.random() > 0.5;
+
+  group('LLM Gateway', () => {
+    const headers = useFlatWarp ? HEADERS_WITH_FLATWARP : HEADERS_WITHOUT_FLATWARP;
+    const res = http.post(`${BASE_URL}/api/v1/llm/chat`, JSON.stringify(payload), { headers });
+
+    llmLatency.add(res.timings.duration);
+
+    if (res.status === 200) {
+      check(res, {
+        'status is 200': () => res.status === 200,
+        'has choices': () => JSON.parse(res.body).choices?.length > 0,
+        'has tokenRemaining': () => {
+          const body = JSON.parse(res.body);
+          return body.tokenRemaining !== undefined || body.usage !== undefined;
+        },
+      });
+    } else if (res.status === 402) {
+      check(res, { 'status is 402 (insufficient balance)': () => res.status === 402 });
+    } else if (res.status === 429) {
+      check(res, { 'status is 429 (rate limited)': () => res.status === 429 });
+    } else {
+      errorRate.add(1);
+      check(res, { 'unexpected status': () => res.status === 200 || res.status === 402 || res.status === 429 });
+    }
+  });
+
+  sleep(Math.random() * 2 + 0.5);
+}
